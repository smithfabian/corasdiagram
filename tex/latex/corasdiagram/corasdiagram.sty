\newcommand{\corasdiagram@computeedgeendpointclearancefrombase}[1]{%
  \corasdiagram@getnodepublicboxdims{#1}{\corasdiagram@endpointwidth}{\corasdiagram@endpointheight}%
  \corasdiagram@computeedgeboxhalfspanfromdims{\corasdiagram@endpointwidth}{\corasdiagram@endpointheight}%
  \corasdiagram@tmpdimen=\corasdiagram@layoutmingap\relax
  \pgfmathsetmacro{\corasdiagram@edgeannotationmarginpt}{max(2,0.3*(\strip@pt\corasdiagram@tmpdimen))}%
  \pgfmathsetmacro{\corasdiagram@endpointclearancept}{\corasdiagram@edgeboxhalfspan + \corasdiagram@edgeannotationmarginpt}%
}

\newcommand{\corasdiagram@computeedgeposlimitsfrombases}[3]{%
  \corasdiagram@computeedgeendpointclearancefrombase{#1}%
  \edef\corasdiagram@sourceclearancept{\corasdiagram@endpointclearancept}%
  \corasdiagram@computeedgeendpointclearancefrombase{#2}%
  \edef\corasdiagram@targetclearancept{\corasdiagram@endpointclearancept}%
  \pgfmathparse{abs(\corasdiagram@edgelen) > 0.01 ? 1 : 0}%
  \ifnum\pgfmathresult=1\relax
    \pgfmathsetmacro{\corasdiagram@edgeposmin}{min(0.97,max(0.03,(\corasdiagram@sourceclearancept + (#3))/\corasdiagram@edgelen))}%
    \pgfmathsetmacro{\corasdiagram@edgeposmax}{max(0.03,min(0.97,1 - ((\corasdiagram@targetclearancept + (#3))/\corasdiagram@edgelen)))}%
    \pgfmathparse{\corasdiagram@edgeposmin > \corasdiagram@edgeposmax ? 1 : 0}%
    \ifnum\pgfmathresult=1\relax
      \pgfmathsetmacro{\corasdiagram@edgeposmid}{0.5*(\corasdiagram@edgeposmin + \corasdiagram@edgeposmax)}%
      \xdef\corasdiagram@edgeposmin{\corasdiagram@edgeposmid}%
      \xdef\corasdiagram@edgeposmax{\corasdiagram@edgeposmid}%
    \fi
  \else
    \def\corasdiagram@edgeposmin{0.5}%
    \def\corasdiagram@edgeposmax{0.5}%
  \fi
}

