}

\NewDocumentCommand{\corascontainer}{O{}}{%
  \pgfkeys{/coras/container/.cd,%
    name=,%
    label=,%
    fit=,%
    tikz=,%
    title tikz=,%
    #1%
  }%
  \corasdiagram@ensurename\corascontainer@name
  \corasdiagram@normalize\corascontainer@tikz
  \corasdiagram@normalize\corascontainer@titletikz
  \ifx\corascontainer@fit\@empty
    \PackageError{corasdiagram}{Missing `fit` key for \string\corascontainer}{%
      Use \string\corascontainer[fit={(a) (b)},label={Container title}].%
    }%
  \else
    \edef\corasdiagram@containeroptions{coras/container,fit=\corascontainer@fit,\corascontainer@tikz}%
    \expandafter\node\expandafter[\corasdiagram@containeroptions] (\corascontainer@name) {};
    \ifx\corascontainer@label\@empty
    \else
      \edef\corasdiagram@containertitleoptions{coras/container title,\corascontainer@titletikz}%
      \expandafter\node\expandafter[\corasdiagram@containertitleoptions]
        (\corascontainer@name-title)
        at ([xshift=2mm,yshift=-2mm]\corascontainer@name.north west)
        {\corascontainer@label};
    \fi
  \fi
}

