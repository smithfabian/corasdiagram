\newcommand{\corasdiagram@groupedmarkerscollide}[2]{%
  \def\corasdiagram@groupedmarkercollision{0}%
  \corasdiagram@getgroupedmarkerprop{basex}{#1}{\corasdiagram@markercurrentx}%
  \corasdiagram@getgroupedmarkerprop{basey}{#1}{\corasdiagram@markercurrenty}%
  \corasdiagram@getgroupedmarkerprop{boxwidth}{#1}{\corasdiagram@markercurrentwidth}%
  \corasdiagram@getgroupedmarkerprop{boxheight}{#1}{\corasdiagram@markercurrentheight}%
  \corasdiagram@getgroupedmarkerprop{basex}{#2}{\corasdiagram@markerpreviousx}%
  \corasdiagram@getgroupedmarkerprop{basey}{#2}{\corasdiagram@markerpreviousy}%
  \corasdiagram@getgroupedmarkerprop{boxwidth}{#2}{\corasdiagram@markerpreviouswidth}%
  \corasdiagram@getgroupedmarkerprop{boxheight}{#2}{\corasdiagram@markerpreviousheight}%
  \corasdiagram@currentx=\corasdiagram@markercurrentx pt\relax
  \advance\corasdiagram@currentx by -\corasdiagram@markerpreviousx pt\relax
  \ifdim\corasdiagram@currentx<0pt\relax
    \corasdiagram@currentx=-\corasdiagram@currentx
  \fi
  \corasdiagram@currenty=\corasdiagram@markercurrenty pt\relax
  \advance\corasdiagram@currenty by -\corasdiagram@markerpreviousy pt\relax
  \ifdim\corasdiagram@currenty<0pt\relax
    \corasdiagram@currenty=-\corasdiagram@currenty
  \fi
  \corasdiagram@estimatedwidth=\corasdiagram@markercurrentwidth pt\relax
  \advance\corasdiagram@estimatedwidth by \corasdiagram@markerpreviouswidth pt\relax
  \corasdiagram@estimatedwidth=.5\corasdiagram@estimatedwidth
  \advance\corasdiagram@estimatedwidth by 1.2mm\relax
  \corasdiagram@estimatedheight=\corasdiagram@markercurrentheight pt\relax
  \advance\corasdiagram@estimatedheight by \corasdiagram@markerpreviousheight pt\relax
  \corasdiagram@estimatedheight=.5\corasdiagram@estimatedheight
  \advance\corasdiagram@estimatedheight by .8mm\relax
  \ifdim\corasdiagram@currentx<\corasdiagram@estimatedwidth
    \ifdim\corasdiagram@currenty<\corasdiagram@estimatedheight
      \def\corasdiagram@groupedmarkercollision{1}%
    \fi
  \fi
}

\newcommand{\corasdiagram@assigngroupedmarkerclusters}{%
  \ifnum\corasdiagram@groupedmarkercount=0\relax
  \else
    \corasdiagram@groupedmarkerindex=1\relax
    \@whilenum\corasdiagram@groupedmarkerindex<\numexpr\corasdiagram@groupedmarkercount+1\relax\do{%
      \corasdiagram@setgroupedmarkerprop{sortused}{\the\corasdiagram@groupedmarkerindex}{0}%
      \advance\corasdiagram@groupedmarkerindex by 1\relax
    }%
    \let\corasdiagram@lastsortedmarker\@empty
    \def\corasdiagram@lastclusterindex{0}%
    \corasdiagram@groupedmarkersortindex=1\relax
    \@whilenum\corasdiagram@groupedmarkersortindex<\numexpr\corasdiagram@groupedmarkercount+1\relax\do{%
      \let\corasdiagram@bestsortedmarker\@empty
      \let\corasdiagram@bestsortedy\@empty
      \corasdiagram@groupedmarkerindex=1\relax
      \@whilenum\corasdiagram@groupedmarkerindex<\numexpr\corasdiagram@groupedmarkercount+1\relax\do{%
        \corasdiagram@getgroupedmarkerprop{sortused}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@markersortused}%
        \ifx\corasdiagram@markersortused\@empty
          \def\corasdiagram@markersortused{0}%
        \fi
        \ifnum\corasdiagram@markersortused=1\relax
        \else
          \corasdiagram@getgroupedmarkerprop{basey}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@candidatebasey}%
          \ifx\corasdiagram@bestsortedmarker\@empty
            \edef\corasdiagram@bestsortedmarker{\the\corasdiagram@groupedmarkerindex}%
            \edef\corasdiagram@bestsortedy{\corasdiagram@candidatebasey}%
          \else
            \ifdim\corasdiagram@candidatebasey pt>\corasdiagram@bestsortedy pt\relax
              \edef\corasdiagram@bestsortedmarker{\the\corasdiagram@groupedmarkerindex}%
              \edef\corasdiagram@bestsortedy{\corasdiagram@candidatebasey}%
            \fi
          \fi
        \fi
        \advance\corasdiagram@groupedmarkerindex by 1\relax
      }%
      \ifx\corasdiagram@bestsortedmarker\@empty
      \else
        \corasdiagram@setgroupedmarkerprop{sortused}{\corasdiagram@bestsortedmarker}{1}%
        \ifx\corasdiagram@lastsortedmarker\@empty
          \def\corasdiagram@currentclusterindex{0}%
        \else
          \corasdiagram@groupedmarkerscollide{\corasdiagram@bestsortedmarker}{\corasdiagram@lastsortedmarker}%
          \ifnum\corasdiagram@groupedmarkercollision=1\relax
            \pgfmathtruncatemacro{\corasdiagram@nextclusterindex}{\corasdiagram@lastclusterindex + 1}%
            \edef\corasdiagram@currentclusterindex{\corasdiagram@nextclusterindex}%
          \else
            \def\corasdiagram@currentclusterindex{0}%
          \fi
        \fi
        \corasdiagram@setgroupedmarkerprop{clusterindex}{\corasdiagram@bestsortedmarker}{\corasdiagram@currentclusterindex}%
        \edef\corasdiagram@lastsortedmarker{\corasdiagram@bestsortedmarker}%
        \edef\corasdiagram@lastclusterindex{\corasdiagram@currentclusterindex}%
      \fi
      \advance\corasdiagram@groupedmarkersortindex by 1\relax
    }%
  \fi
}

\newcommand{\corasdiagram@renderstoredgroupedmarker}[1]{%
  \corasdiagram@getgroupedmarkerprop{node}{#1}{\corasdiagram@groupednode}%
  \corasdiagram@getgroupedmarkerprop{from}{#1}{\corasdiagram@groupedgefrom}%
  \corasdiagram@getgroupedmarkerprop{to}{#1}{\corasdiagram@groupedgeto}%
  \corasdiagram@getgroupedmarkerprop{frombase}{#1}{\corasdiagram@groupedgefrombase}%
  \corasdiagram@getgroupedmarkerprop{tobase}{#1}{\corasdiagram@groupedgetobase}%
  \corasdiagram@getgroupedmarkerprop{basex}{#1}{\corasdiagram@groupedbasex}%
  \corasdiagram@getgroupedmarkerprop{basey}{#1}{\corasdiagram@groupedbasey}%
  \corasdiagram@getgroupedmarkerprop{dx}{#1}{\corasdiagram@groupeddx}%
  \corasdiagram@getgroupedmarkerprop{dy}{#1}{\corasdiagram@groupeddy}%
  \corasdiagram@getgroupedmarkerprop{len}{#1}{\corasdiagram@groupedlen}%
  \corasdiagram@getgroupedmarkerprop{basepos}{#1}{\corasdiagram@groupedbasepos}%
  \corasdiagram@getgroupedmarkerprop{boxwidth}{#1}{\corasdiagram@groupedboxwidth}%
  \corasdiagram@getgroupedmarkerprop{boxheight}{#1}{\corasdiagram@groupedboxheight}%
  \corasdiagram@getgroupedmarkerprop{clusterindex}{#1}{\corasdiagram@groupedclusterindex}%
  \corasdiagram@getgroupedmarkerprop{densemode}{#1}{\corasdiagram@groupeddensemode}%
  \ifx\corasdiagram@groupedclusterindex\@empty
    \def\corasdiagram@groupedclusterindex{0}%
  \fi
  \ifx\corasdiagram@groupeddensemode\@empty
    \def\corasdiagram@groupeddensemode{0}%
  \fi
  \ifnum\corasdiagram@groupedclusterindex=0\relax
    \def\corasdiagram@groupedshiftstep{0}%
  \else
    \pgfmathtruncatemacro{\corasdiagram@groupedshiftmagnitude}{(\corasdiagram@groupedclusterindex + 1) / 2}%
    \pgfmathtruncatemacro{\corasdiagram@groupedshiftodd}{mod(\corasdiagram@groupedclusterindex,2)}%
    \ifnum\corasdiagram@groupedshiftodd=1\relax
      \edef\corasdiagram@groupedshiftstep{\corasdiagram@groupedshiftmagnitude}%
    \else
      \pgfmathtruncatemacro{\corasdiagram@groupedshiftnegative}{-\corasdiagram@groupedshiftmagnitude}%
      \edef\corasdiagram@groupedshiftstep{\corasdiagram@groupedshiftnegative}%
    \fi
  \fi
  \pgfmathsetmacro{\corasdiagram@groupedshiftunit}{max(19.9,max(0.55*(\corasdiagram@groupedboxwidth),0.6*(\corasdiagram@groupedboxheight)))}%
  \pgfmathsetmacro{\corasdiagram@groupedrequestedshift}{abs(\corasdiagram@groupedshiftstep)*\corasdiagram@groupedshiftunit}%
  \pgfmathsetmacro{\corasdiagram@groupedmaxshift}{\corasdiagram@groupedrequestedshift}%
  \corasdiagram@measureedgegeometry{\corasdiagram@groupedgefrom}{\corasdiagram@groupedgeto}%
  \corasdiagram@getgroupedmarkerprop{corehalfspan}{#1}{\corasdiagram@groupedmarkerhalfspanpt}%
  \ifx\corasdiagram@groupedmarkerhalfspanpt\@empty
    \corasdiagram@measuregroupedmarkerhalfspan{#1}%
  \else
    \xdef\corasdiagram@groupedmarkerhalfspanpt{\corasdiagram@groupedmarkerhalfspanpt}%
  \fi
  \corasdiagram@computeedgeposlimitsfrombases{\corasdiagram@groupedgefrombase}{\corasdiagram@groupedgetobase}{\corasdiagram@groupedmarkerhalfspanpt}%
  \pgfmathparse{abs(\corasdiagram@groupedlen) > 0.01 ? 1 : 0}%
  \ifnum\pgfmathresult=1\relax
    \ifnum\corasdiagram@groupedshiftstep>0\relax
      \pgfmathsetmacro{\corasdiagram@groupedmaxshift}{max(0,(\corasdiagram@edgeposmax - \corasdiagram@groupedbasepos)*\corasdiagram@groupedlen)}%
    \else\ifnum\corasdiagram@groupedshiftstep<0\relax
      \pgfmathsetmacro{\corasdiagram@groupedmaxshift}{max(0,(\corasdiagram@groupedbasepos - \corasdiagram@edgeposmin)*\corasdiagram@groupedlen)}%
    \fi\fi
  \fi
  \pgfmathsetmacro{\corasdiagram@groupedshiftamount}{min(\corasdiagram@groupedrequestedshift,\corasdiagram@groupedmaxshift)}%
  \ifnum\corasdiagram@groupedshiftstep<0\relax
    \pgfmathsetmacro{\corasdiagram@groupedshiftamount}{-\corasdiagram@groupedshiftamount}%
  \fi
  \pgfmathsetmacro{\corasdiagram@groupedfinalx}{\corasdiagram@groupedbasex}%
  \pgfmathsetmacro{\corasdiagram@groupedfinaly}{\corasdiagram@groupedbasey}%
  \pgfmathsetmacro{\corasdiagram@groupedfinalpos}{\corasdiagram@groupedbasepos}%
  \pgfmathsetmacro{\corasdiagram@groupedperpshiftamount}{0}%
  \ifnum\corasdiagram@groupeddensemode=1\relax
    \pgfmathsetmacro{\corasdiagram@groupedperpshiftunit}{max(14,max(0.62*(\corasdiagram@groupedboxheight),0.18*(\corasdiagram@groupedboxwidth)))}%
    \pgfmathsetmacro{\corasdiagram@groupedperpshiftamount}{\corasdiagram@groupedshiftstep*\corasdiagram@groupedperpshiftunit}%
    \pgfmathsetmacro{\corasdiagram@groupedshiftamount}{0}%
  \fi
  \pgfmathparse{abs(\corasdiagram@groupedlen) > 0.01 ? 1 : 0}%
  \ifnum\pgfmathresult=1\relax
    \pgfmathsetmacro{\corasdiagram@groupedfinalx}{\corasdiagram@groupedbasex + \corasdiagram@groupedshiftamount*(\corasdiagram@groupeddx/\corasdiagram@groupedlen)}%
    \pgfmathsetmacro{\corasdiagram@groupedfinaly}{\corasdiagram@groupedbasey + \corasdiagram@groupedshiftamount*(\corasdiagram@groupeddy/\corasdiagram@groupedlen)}%
    \pgfmathsetmacro{\corasdiagram@groupedfinalpos}{\corasdiagram@groupedbasepos + (\corasdiagram@groupedshiftamount/\corasdiagram@groupedlen)}%
  \fi
  \pgfmathsetmacro{\corasdiagram@groupedfinalpos}{min(\corasdiagram@edgeposmax,max(\corasdiagram@edgeposmin,\corasdiagram@groupedfinalpos))}%
  \corasdiagram@computeedgepointfrompos{\corasdiagram@groupedfinalpos}%
  \pgfmathsetmacro{\corasdiagram@groupedfinalx}{\corasdiagram@edgepointx}%
  \pgfmathsetmacro{\corasdiagram@groupedfinaly}{\corasdiagram@edgepointy}%
  \pgfmathparse{abs(\corasdiagram@groupedlen) > 0.01 ? 1 : 0}%
  \ifnum\pgfmathresult=1\relax
    \ifnum\corasdiagram@groupeddensemode=1\relax
      \pgfmathsetmacro{\corasdiagram@groupedperpshiftunit}{max(18,max(0.9*(\corasdiagram@groupedboxheight),0.22*(\corasdiagram@groupedboxwidth)))}%
      \pgfmathsetmacro{\corasdiagram@groupedperpshiftamount}{\corasdiagram@groupedshiftstep*\corasdiagram@groupedperpshiftunit}%
    \fi
    \pgfmathsetmacro{\corasdiagram@groupedfinalx}{\corasdiagram@groupedfinalx + \corasdiagram@groupedperpshiftamount*(-\corasdiagram@groupeddy/\corasdiagram@groupedlen)}%
    \pgfmathsetmacro{\corasdiagram@groupedfinaly}{\corasdiagram@groupedfinaly + \corasdiagram@groupedperpshiftamount*(\corasdiagram@groupeddx/\corasdiagram@groupedlen)}%
  \fi
  \corasdiagram@setgroupedmarkerprop{finalpos}{#1}{\corasdiagram@groupedfinalpos}%
  \edef\corasdiagram@groupedfinalcoord{(\corasdiagram@groupedfinalx pt,\corasdiagram@groupedfinaly pt)}%
  \corasdiagram@drawgroupedvulnerabilitydisplayat{\corasdiagram@groupednode}{\corasdiagram@groupedfinalcoord}%
}

