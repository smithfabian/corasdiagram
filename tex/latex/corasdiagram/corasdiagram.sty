\newcommand{\corasdiagram@typednode}[3]{%
  \def\corasdiagram@threatfamily{threat}%
  \ifx\corasdiagram@currentfamily\corasdiagram@threatfamily
    \corasdiagram@collecttypedthreatnode{#1}{#2}{#3}%
  \else
    \corasdiagram@preparetypednodekeys{#1}{#2}{#3}%
    \let\corasnode@resolvedorder\@empty
    \corasdiagram@applydslanehint
    \corasdiagram@maptyperole{\corasnode@type}%
    \edef\corasnode@role{\corasdiagram@mappedrole}%
    \corasdiagram@computetypedlegacyorderhint
    \def\corasdiagram@typedlaneoption{}%
    \def\corasdiagram@typedorderoption{}%
    \ifx\corasnode@lane\@empty
    \else
      \edef\corasdiagram@typedlaneoption{,lane={\corasnode@lane}}%
    \fi
    \ifx\corasnode@order\@empty
    \else
      \edef\corasdiagram@typedorderoption{,order={\corasnode@order}}%
    \fi
    \edef\corasdiagram@typednodeoptions{type=#1,title={#3},#2\corasdiagram@typedlaneoption\corasdiagram@typedorderoption}%
    \expandafter\corasnode\expandafter[\corasdiagram@typednodeoptions]%
  \fi
}

\newcommand{\corasdiagram@resolvethreattype}[1]{%
  \edef\corasdiagram@dslthreatsubtype{\corasdiagramtrimspaces{#1}}%
  \def\corasdiagram@dslthreattype{}%
  \def\corasdiagram@subtypedeliberate{deliberate}%
  \def\corasdiagram@subtypeaccidental{accidental}%
  \def\corasdiagram@subtypenonhuman{nonhuman}%
  \def\corasdiagram@subtypenonhumanalt{non-human}%
  \ifx\corasdiagram@dslthreatsubtype\corasdiagram@subtypedeliberate
    \def\corasdiagram@dslthreattype{threatdeliberate}%
  \else\ifx\corasdiagram@dslthreatsubtype\corasdiagram@subtypeaccidental
    \def\corasdiagram@dslthreattype{threataccidental}%
  \else\ifx\corasdiagram@dslthreatsubtype\corasdiagram@subtypenonhuman
    \def\corasdiagram@dslthreattype{threatnonhuman}%
  \else\ifx\corasdiagram@dslthreatsubtype\corasdiagram@subtypenonhumanalt
    \def\corasdiagram@dslthreattype{threatnonhuman}%
  \else
    \PackageError{corasdiagram}{Unknown threat subtype `#1'}{%
      Use `deliberate`, `accidental`, or `nonhuman` in \string\threat(...).%
    }%
  \fi\fi\fi\fi
}

