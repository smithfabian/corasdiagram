  \corasdiagram@settypednodeprop{manual}{\corasnode@name}{\corasdiagram@typedmanualflag}%
  \corasdiagram@storetypedthreatnodeprops{\corasnode@name}%
  \global\advance\corasdiagram@typedthreatdeclorder by 1\relax
  \corasdiagram@settypednodeprop{declorder}{\corasnode@name}{\the\corasdiagram@typedthreatdeclorder}%
  \corasdiagram@registertypedthreatnode{\corasnode@name}%
