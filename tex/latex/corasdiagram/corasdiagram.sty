\newcommand{\corasdiagram@validatenodesemantickeys}{%
  \ifx\corasnode@removedmeta\@empty
  \else
    \PackageError{corasdiagram}{Node key `meta` has been removed}{%
      Use semantic keys such as `likelihood basis`, `likelihood`, `risk level`, or `risk ref` instead.%
    }%
  \fi
  \ifx\corasnode@removedlevel\@empty
  \else
    \PackageError{corasdiagram}{Node key `level` has been removed}{%
      Use `risk level=<text>` on risk nodes.%
    }%
  \fi
  \ifx\corasnode@removedvalue\@empty
  \else
    \PackageError{corasdiagram}{Node key `value` has been removed}{%
      Use `asset value=<text>` on \string\assigns\space edges instead of a node-level `value=` key.%
    }%
  \fi
  \ifx\corasnode@removedlikelihoodlabel\@empty
  \else
    \PackageError{corasdiagram}{Node key `likelihood label` has been removed}{%
      Use `likelihood=<english label>` and `likelihood basis=<range or quantitative basis>` instead.%
    }%
  \fi
  \ifx\corasnode@likelihood\@empty
  \else
    \corasdiagram@ifincsv{\corasnode@type}{scenario,incident}{}{%
      \PackageError{corasdiagram}{Node key `likelihood basis` is only valid on threat scenario and unwanted incident nodes}{%
        Use `likelihood basis=<text>` on threat scenario or unwanted incident nodes.%
      }%
    }%
  \fi
  \ifx\corasnode@likelihoodlabel\@empty
  \else
    \corasdiagram@ifincsv{\corasnode@type}{scenario,incident}{}{%
      \PackageError{corasdiagram}{Node key `likelihood` is only valid on threat scenario and unwanted incident nodes}{%
        Use `likelihood=<english label>` on threat scenario or unwanted incident nodes.%
      }%
    }%
  \fi
  \ifx\corasnode@riskid\@empty
  \else
    \corasdiagram@ifincsv{\corasnode@type}{risk,incident}{}{%
      \PackageError{corasdiagram}{Node key `risk ref` is only valid on risk and unwanted incident nodes}{%
        Use `risk ref=<text>` on risk or unwanted incident nodes.%
      }%
    }%
  \fi
  \ifx\corasnode@level\@empty
  \else
    \def\corasdiagram@risktype{risk}%
    \ifx\corasnode@type\corasdiagram@risktype
    \else
      \PackageError{corasdiagram}{Node key `risk level` is only valid on risk nodes}{%
        Use `risk level=<text>` on \string\risk\space nodes only.%
      }%
    \fi
  \fi
}

\NewDocumentCommand{\corasnode}{O{}}{%
  \def\corasnode@meta{}%
  \def\corasnode@value{}%
  \def\corasnode@removedmeta{}%
  \def\corasnode@removedlevel{}%
  \def\corasnode@removedlikelihoodlabel{}%
  \def\corasnode@removedvalue{}%
  \pgfkeys{/coras/node/.cd,%
    type=asset,%
    id=,%
    name=,%
    title=,%
    label=,%
    risk level=,%
    risk ref=,%
    likelihood=,%
    likelihood basis=,%
    perspective=before,%
    at=,%
    scope=,%
    lane=,%
    order=,%
    text width=,%
    icon width=,%
    anchor style=,%
    anchor width=,%
    anchor height=,%
    label gap=,%
    layout=,%
    min edge gap=,%
    right of=,%
    left of=,%
    below of=,%
    above of=,%
    incident of=,%
    treats=,%
    harms=,%
    horizontal gap=12mm,%
    vertical gap=14mm,%
    tikz=,%
    #1%
  }%
  \let\corasnode@resolvedorder\@empty
  \corasdiagram@resolveidalias
  \corasdiagram@applydslanehint
  \ifx\corasnode@name\@empty
  \else
    \corasdiagram@validatenodenameavailable{\corasnode@name}%
  \fi
  \corasdiagram@ensurename\corasnode@name
  \ifx\corasnode@title\@empty
    \edef\corasnode@title{\corasnode@label}%
  \fi
  \corasdiagram@maptyperole{\corasnode@type}%
  \edef\corasnode@role{\corasdiagram@mappedrole}%
  \corasdiagram@validatenodesemantickeys
  \corasdiagram@activaterisklayoutifneeded
  \corasdiagram@validateplacementreferences
  \corasdiagram@resolveplacement
  \corasdiagram@normalize\corasnode@tikz
  \let\corasnode@anchorsymbol\@empty
  \@ifundefined{corasdiagram@render@\corasnode@type}{%
    \PackageError{corasdiagram}{Unknown node type `\corasnode@type'}{%
      Valid node types are asset, stakeholder, threataccidental,
      threatdeliberate, threatnonhuman, vulnerability, indirectasset, scenario,
      incident, risk, treatment, and junction.%
    }%
  }{%
    \corasdiagram@marknodeknown{\corasnode@name}%
    \csname corasdiagram@render@\corasnode@type\endcsname
    \corasdiagram@registernode{\corasnode@name}%
  }%
}

