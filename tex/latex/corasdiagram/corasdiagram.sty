\newcommand{\corasdiagram@measureedgegeometry}[2]{%
  \path let \p1=(#1), \p2=(#2) in \pgfextra{%
    \pgfmathsetmacro{\corasdiagram@edgefromx}{\x1}%
    \pgfmathsetmacro{\corasdiagram@edgefromy}{\y1}%
    \pgfmathsetmacro{\corasdiagram@edgedx}{\x2-\x1}%
    \pgfmathsetmacro{\corasdiagram@edgedy}{\y2-\y1}%
    \pgfmathsetmacro{\corasdiagram@edgelen}{veclen(\corasdiagram@edgedx,\corasdiagram@edgedy)}%
    \xdef\corasdiagram@edgefromx{\corasdiagram@edgefromx}%
    \xdef\corasdiagram@edgefromy{\corasdiagram@edgefromy}%
    \xdef\corasdiagram@edgedx{\corasdiagram@edgedx}%
    \xdef\corasdiagram@edgedy{\corasdiagram@edgedy}%
    \xdef\corasdiagram@edgelen{\corasdiagram@edgelen}%
  };%
}

\newcommand{\corasdiagram@computeedgepointfrompos}[1]{%
