  \corasdiagram@setnodeprop{displaylevel}{\corasnode@name}{\corasnode@level}%
  \corasdiagram@setnodeprop{displaylikelihood}{\corasnode@name}{\corasnode@likelihood}%
  \corasdiagram@setnodeprop{displaylikelihoodlabel}{\corasnode@name}{\corasnode@likelihoodlabel}%
  \corasdiagram@setnodeprop{displaytextwidth}{\corasnode@name}{\corasnode@textwidth}%
  \corasdiagram@setnodeprop{displayiconwidth}{\corasnode@name}{\corasnode@iconwidth}%
  \corasdiagram@setnodeprop{displaylabelgap}{\corasnode@name}{\corasnode@labelgap}%
  \corasdiagram@setnodeprop{displayperspective}{\corasnode@name}{\corasnode@perspective}%
  \corasdiagram@setnodeprop{displayiconstem}{\corasnode@name}{\corasdiagram@resolvediconstem}%
