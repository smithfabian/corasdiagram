          \l__corasdiagram_item_tl
        \tl_trim_spaces:N \l__corasdiagram_item_tl
        \tl_if_blank:VTF \l__corasdiagram_item_tl
          { }
          {
            \tl_if_blank:VTF \l__corasdiagram_result_tl
              { }
              { \tl_put_right:Nn \l__corasdiagram_result_tl {,} }
            \tl_put_right:NV \l__corasdiagram_result_tl \l__corasdiagram_item_tl
            \int_incr:N \l_tmpa_int
          }
      }
    \cs_set_nopar:Npx #2 { \tl_use:N \l__corasdiagram_result_tl }
    \cs_set_nopar:Npx #3 { \int_use:N \l_tmpa_int }
