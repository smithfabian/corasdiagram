  /coras/riskref/.is family,
  /coras/riskref,
  name/.store in=\corasriskref@name,
  label/.store in=\corasriskref@label,
  from/.store in=\corasriskref@from,
  to/.store in=\corasriskref@to,
  pos/.store in=\corasriskref@pos,
