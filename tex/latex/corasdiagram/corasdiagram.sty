    \corasdiagram@renderinvisiblevulnerabilityplaceholder
  \else\ifx\corasdiagram@currentfamily\corasdiagram@treatmentfamily
    \corasdiagram@renderinvisiblevulnerabilityplaceholder
  \else
    \corasdiagram@rendericonlabelnode{\corasdiagram@resolvediconstem}%
  \fi\fi\fi
}

