  \corasdiagram@getprobabilitylabelprop{to}{#1}{\corasdiagram@probabilityto}%
  \corasdiagram@getprobabilitylabelprop{frombase}{#1}{\corasdiagram@probabilityfrombase}%
  \corasdiagram@getprobabilitylabelprop{tobase}{#1}{\corasdiagram@probabilitytobase}%
  \corasdiagram@getprobabilitylabelprop{text}{#1}{\corasdiagram@probabilitytext}%
  \corasdiagram@getprobabilitylabelprop{labeloptions}{#1}{\corasdiagram@probabilitylabeloptions}%
  \corasdiagram@getprobabilitylabelprop{pos}{#1}{\corasdiagram@probabilityrequestedpos}%
  \corasdiagram@getprobabilitylabelprop{posexplicit}{#1}{\corasdiagram@probabilityposexplicit}%
  \ifx\corasdiagram@probabilitytext\@empty
  \else
    \corasdiagram@measureprobabilitylabel{\corasdiagram@probabilitytext}%
    \corasdiagram@measureedgegeometry{\corasdiagram@probabilityfrom}{\corasdiagram@probabilityto}%
    \edef\corasdiagram@probabilitydx{\corasdiagram@edgedx}%
    \edef\corasdiagram@probabilitydy{\corasdiagram@edgedy}%
    \edef\corasdiagram@probabilitylen{\corasdiagram@edgelen}%
    \corasdiagram@computeedgeboxhalfspanfromptnums{\the\corasdiagram@estimatedwidth/1pt}{10}%
    \xdef\corasdiagram@probabilitylabelhalfspanpt{\corasdiagram@edgeboxhalfspan}%
    \corasdiagram@computeedgeposlimitsfrombases{\corasdiagram@probabilityfrombase}{\corasdiagram@probabilitytobase}{\corasdiagram@probabilitylabelhalfspanpt}%
    \pgfmathsetmacro{\corasdiagram@probabilityrequestedpos}{min(\corasdiagram@edgeposmax,max(\corasdiagram@edgeposmin,\corasdiagram@probabilityrequestedpos))}%
    \edef\corasdiagram@probabilityleftcandidate{\corasdiagram@probabilityrequestedpos}%
    \def\corasdiagram@probabilitychanged{1}%
    \loop
      \def\corasdiagram@probabilitychanged{0}%
      \corasdiagram@groupedmarkerindex=1\relax
      \@whilenum\corasdiagram@groupedmarkerindex<\numexpr\corasdiagram@groupedmarkercount+1\relax\do{%
        \corasdiagram@getgroupedmarkerprop{probabilitylabel}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@markerprobabilityid}%
        \ifx\corasdiagram@markerprobabilityid\@empty
        \else
          \edef\corasdiagram@currentprobabilitylabelid{#1}%
          \ifx\corasdiagram@markerprobabilityid\corasdiagram@currentprobabilitylabelid
            \corasdiagram@getgroupedmarkerprop{finalpos}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@markerfinalpos}%
            \corasdiagram@getgroupedmarkerprop{corehalfspan}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@markercorehalfspanpt}%
            \ifx\corasdiagram@markercorehalfspanpt\@empty
              \corasdiagram@measuregroupedmarkerhalfspan{\the\corasdiagram@groupedmarkerindex}%
              \edef\corasdiagram@markercorehalfspanpt{\corasdiagram@groupedmarkerhalfspanpt}%
            \fi
            \pgfmathsetmacro{\corasdiagram@markercorehalfspan}{\corasdiagram@markercorehalfspanpt/max(1,\corasdiagram@probabilitylen)}%
            \pgfmathsetmacro{\corasdiagram@probabilitylabelhalfspan}{\corasdiagram@probabilitylabelhalfspanpt/max(1,\corasdiagram@probabilitylen)}%
            \pgfmathsetmacro{\corasdiagram@markerintervalleft}{max(\corasdiagram@edgeposmin,\corasdiagram@markerfinalpos - \corasdiagram@markercorehalfspan - \corasdiagram@probabilitylabelhalfspan - 0.01)}%
            \pgfmathsetmacro{\corasdiagram@markerintervalright}{min(\corasdiagram@edgeposmax,\corasdiagram@markerfinalpos + \corasdiagram@markercorehalfspan + \corasdiagram@probabilitylabelhalfspan + 0.01)}%
            \ifdim\corasdiagram@probabilityleftcandidate pt>\corasdiagram@markerintervalleft pt\relax
              \ifdim\corasdiagram@probabilityleftcandidate pt<\corasdiagram@markerintervalright pt\relax
                \pgfmathsetmacro{\corasdiagram@probabilityleftcandidate}{\corasdiagram@markerintervalleft - 0.005}%
                \def\corasdiagram@probabilitychanged{1}%
              \fi
            \fi
          \fi
        \fi
        \advance\corasdiagram@groupedmarkerindex by 1\relax
      }%
    \ifnum\corasdiagram@probabilitychanged=1\relax
    \repeat
    \def\corasdiagram@probabilityleftvalid{1}%
    \ifdim\corasdiagram@probabilityleftcandidate pt<\corasdiagram@edgeposmin pt\relax
      \def\corasdiagram@probabilityleftvalid{0}%
    \fi
    \edef\corasdiagram@probabilityrightcandidate{\corasdiagram@probabilityrequestedpos}%
    \def\corasdiagram@probabilitychanged{1}%
    \loop
      \def\corasdiagram@probabilitychanged{0}%
      \corasdiagram@groupedmarkerindex=1\relax
      \@whilenum\corasdiagram@groupedmarkerindex<\numexpr\corasdiagram@groupedmarkercount+1\relax\do{%
        \corasdiagram@getgroupedmarkerprop{probabilitylabel}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@markerprobabilityid}%
        \ifx\corasdiagram@markerprobabilityid\@empty
        \else
          \edef\corasdiagram@currentprobabilitylabelid{#1}%
          \ifx\corasdiagram@markerprobabilityid\corasdiagram@currentprobabilitylabelid
            \corasdiagram@getgroupedmarkerprop{finalpos}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@markerfinalpos}%
            \corasdiagram@getgroupedmarkerprop{corehalfspan}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@markercorehalfspanpt}%
            \ifx\corasdiagram@markercorehalfspanpt\@empty
              \corasdiagram@measuregroupedmarkerhalfspan{\the\corasdiagram@groupedmarkerindex}%
              \edef\corasdiagram@markercorehalfspanpt{\corasdiagram@groupedmarkerhalfspanpt}%
            \fi
            \pgfmathsetmacro{\corasdiagram@markercorehalfspan}{\corasdiagram@markercorehalfspanpt/max(1,\corasdiagram@probabilitylen)}%
            \pgfmathsetmacro{\corasdiagram@probabilitylabelhalfspan}{\corasdiagram@probabilitylabelhalfspanpt/max(1,\corasdiagram@probabilitylen)}%
            \pgfmathsetmacro{\corasdiagram@markerintervalleft}{max(\corasdiagram@edgeposmin,\corasdiagram@markerfinalpos - \corasdiagram@markercorehalfspan - \corasdiagram@probabilitylabelhalfspan - 0.01)}%
            \pgfmathsetmacro{\corasdiagram@markerintervalright}{min(\corasdiagram@edgeposmax,\corasdiagram@markerfinalpos + \corasdiagram@markercorehalfspan + \corasdiagram@probabilitylabelhalfspan + 0.01)}%
            \ifdim\corasdiagram@probabilityrightcandidate pt>\corasdiagram@markerintervalleft pt\relax
              \ifdim\corasdiagram@probabilityrightcandidate pt<\corasdiagram@markerintervalright pt\relax
                \pgfmathsetmacro{\corasdiagram@probabilityrightcandidate}{\corasdiagram@markerintervalright + 0.005}%
                \def\corasdiagram@probabilitychanged{1}%
              \fi
            \fi
          \fi
        \fi
        \advance\corasdiagram@groupedmarkerindex by 1\relax
      }%
    \ifnum\corasdiagram@probabilitychanged=1\relax
    \repeat
    \def\corasdiagram@probabilityrightvalid{1}%
    \ifdim\corasdiagram@probabilityrightcandidate pt>\corasdiagram@edgeposmax pt\relax
      \def\corasdiagram@probabilityrightvalid{0}%
    \fi
    \ifx\corasdiagram@probabilityposexplicit\@empty
      \def\corasdiagram@probabilityposexplicit{0}%
    \fi
    \ifnum\corasdiagram@probabilityposexplicit=1\relax
      \ifnum\corasdiagram@probabilityleftvalid=1\relax
        \ifnum\corasdiagram@probabilityrightvalid=1\relax
          \corasdiagram@currentx=\corasdiagram@probabilityrequestedpos pt\relax
          \advance\corasdiagram@currentx by -\corasdiagram@probabilityleftcandidate pt\relax
          \ifdim\corasdiagram@currentx<0pt\relax
            \corasdiagram@currentx=-\corasdiagram@currentx
          \fi
          \corasdiagram@currenty=\corasdiagram@probabilityrightcandidate pt\relax
          \advance\corasdiagram@currenty by -\corasdiagram@probabilityrequestedpos pt\relax
          \ifdim\corasdiagram@currenty<0pt\relax
            \corasdiagram@currenty=-\corasdiagram@currenty
          \fi
          \ifdim\corasdiagram@currentx<\corasdiagram@currenty
            \edef\corasdiagram@probabilityfinalpos{\corasdiagram@probabilityleftcandidate}%
          \else\ifdim\corasdiagram@currenty<\corasdiagram@currentx
            \edef\corasdiagram@probabilityfinalpos{\corasdiagram@probabilityrightcandidate}%
          \else
            \edef\corasdiagram@probabilityfinalpos{\corasdiagram@probabilityleftcandidate}%
          \fi\fi
        \else
          \edef\corasdiagram@probabilityfinalpos{\corasdiagram@probabilityleftcandidate}%
        \fi
      \else\ifnum\corasdiagram@probabilityrightvalid=1\relax
        \edef\corasdiagram@probabilityfinalpos{\corasdiagram@probabilityrightcandidate}%
      \else
        \edef\corasdiagram@probabilityfinalpos{\corasdiagram@probabilityrequestedpos}%
      \fi\fi
    \else
      \ifnum\corasdiagram@probabilityleftvalid=1\relax
        \edef\corasdiagram@probabilityfinalpos{\corasdiagram@probabilityleftcandidate}%
      \else\ifnum\corasdiagram@probabilityrightvalid=1\relax
        \edef\corasdiagram@probabilityfinalpos{\corasdiagram@probabilityrightcandidate}%
      \else
        \edef\corasdiagram@probabilityfinalpos{\corasdiagram@probabilityrequestedpos}%
      \fi\fi
    \fi
    \pgfmathsetmacro{\corasdiagram@probabilityfinalpos}{min(\corasdiagram@edgeposmax,max(\corasdiagram@edgeposmin,\corasdiagram@probabilityfinalpos))}%
    \edef\corasdiagram@probabilitynodeoptions{coras/base node,\corasdiagram@probabilitylabeloptions}%
    \expandafter\node\expandafter[\corasdiagram@probabilitynodeoptions] at ($ (\corasdiagram@probabilityfrom)!\corasdiagram@probabilityfinalpos!(\corasdiagram@probabilityto) $) {%
      \corasdiagram@probabilitytext
    };
  \fi
}

