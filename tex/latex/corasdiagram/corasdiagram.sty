    \ifnum\corasdiagram@previousorder>0\relax
      \corasdiagram@getroleordernode{\corasdiagram@adjacentnode}{#1}{\corasdiagram@previousorder}%
      \corasdiagram@enforcerightofnode{\corasdiagram@adjacentnode}%
    \fi
  \fi
