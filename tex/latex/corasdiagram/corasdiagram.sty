          \corasdiagram@setgroupedmarkerprop{corehalfspan}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@groupedmarkerhalfspanpt}%
          \pgfmathsetmacro{\corasdiagram@groupedgetotaldiameter}{\corasdiagram@groupedgetotaldiameter + 2*(\corasdiagram@groupedmarkerhalfspanpt)}%
          \corasdiagram@getgroupedmarkerprop{boxwidth}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@groupedmarkerboxwidth}%
          \corasdiagram@getgroupedmarkerprop{boxheight}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@groupedmarkerboxheight}%
          \pgfmathsetmacro{\corasdiagram@groupedgemaxboxwidth}{max(\corasdiagram@groupedgemaxboxwidth,\corasdiagram@groupedmarkerboxwidth)}%
          \pgfmathsetmacro{\corasdiagram@groupedgemaxboxheight}{max(\corasdiagram@groupedgemaxboxheight,\corasdiagram@groupedmarkerboxheight)}%
        \fi
      \fi
      \advance\corasdiagram@groupedmarkerindex by 1\relax
    }%
    \pgfmathsetmacro{\corasdiagram@groupedgefreept}{\corasdiagram@groupedgeavailablept - \corasdiagram@groupedgetotaldiameter}%
    \def\corasdiagram@groupedgedensemode{0}%
    \pgfmathsetmacro{\corasdiagram@groupedgeslotwidthpt}{\corasdiagram@groupedgeavailablept/max(1,\corasdiagram@groupedmarkersforedge)}%
    \ifnum\corasdiagram@groupedmarkersforedge=1\relax
      \pgfmathsetmacro{\corasdiagram@groupedgeoutergappt}{max(0,0.5*\corasdiagram@groupedgefreept)}%
      \pgfmathsetmacro{\corasdiagram@groupedgeintergappt}{0}%
    \else
      \pgfmathparse{\corasdiagram@groupedgefreept >= 0 ? 1 : 0}%
      \ifnum\pgfmathresult=1\relax
        \pgfmathsetmacro{\corasdiagram@groupedgeoutergappt}{\corasdiagram@groupedgefreept/(\corasdiagram@groupedmarkersforedge + 1)}%
        \pgfmathsetmacro{\corasdiagram@groupedgeintergappt}{\corasdiagram@groupedgeoutergappt}%
        \pgfmathparse{\corasdiagram@groupedgeslotwidthpt < 1.15*\corasdiagram@groupedgemaxboxwidth ? 1 : 0}%
        \ifnum\pgfmathresult=1\relax
          \pgfmathsetmacro{\corasdiagram@groupedgeoutergappt}{0}%
          \pgfmathsetmacro{\corasdiagram@groupedgeintergappt}{0}%
          \def\corasdiagram@groupedgedensemode{1}%
        \fi
      \else
        \pgfmathsetmacro{\corasdiagram@groupedgeoutergappt}{0}%
        \pgfmathsetmacro{\corasdiagram@groupedgeintergappt}{0}%
        \def\corasdiagram@groupedgedensemode{1}%
      \fi
    \fi
    \pgfmathsetmacro{\corasdiagram@groupedgecurrentleftpt}{\corasdiagram@groupedgeleftpt + \corasdiagram@groupedgeoutergappt}%
    \def\corasdiagram@groupedmarkerordinal{0}%
    \corasdiagram@groupedmarkerindex=1\relax
    \@whilenum\corasdiagram@groupedmarkerindex<\numexpr\corasdiagram@groupedmarkercount+1\relax\do{%
      \corasdiagram@getgroupedmarkerprop{edgegroup}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@groupedmarkergroup}%
      \ifx\corasdiagram@groupedmarkergroup\@empty
      \else
        \ifnum\corasdiagram@groupedmarkergroup=#1\relax
          \corasdiagram@getgroupedmarkerprop{corehalfspan}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@groupedmarkerhalfspanpt}%
          \pgfmathtruncatemacro{\corasdiagram@groupedmarkerordinalnext}{\corasdiagram@groupedmarkerordinal + 1}%
          \edef\corasdiagram@groupedmarkerordinal{\corasdiagram@groupedmarkerordinalnext}%
          \ifnum\corasdiagram@groupedgedensemode=1\relax
            \pgfmathsetmacro{\corasdiagram@groupedgecenterpt}{\corasdiagram@groupedgeleftpt + (\corasdiagram@groupedmarkerordinal - 0.5)*\corasdiagram@groupedgeslotwidthpt}%
          \else
            \pgfmathsetmacro{\corasdiagram@groupedgecenterpt}{\corasdiagram@groupedgecurrentleftpt + \corasdiagram@groupedmarkerhalfspanpt}%
          \fi
          \pgfmathsetmacro{\corasdiagram@groupedgecenterpos}{abs(\corasdiagram@edgelen) > 0.01 ? \corasdiagram@groupedgecenterpt/\corasdiagram@edgelen : 0.5}%
          \pgfmathsetmacro{\corasdiagram@groupedgecenterpos}{min(\corasdiagram@edgeposmax,max(\corasdiagram@edgeposmin,\corasdiagram@groupedgecenterpos))}%
          \corasdiagram@computeedgepointfrompos{\corasdiagram@groupedgecenterpos}%
          \corasdiagram@setgroupedmarkerprop{basepos}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@groupedgecenterpos}%
          \corasdiagram@setgroupedmarkerprop{basex}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@edgepointx}%
          \corasdiagram@setgroupedmarkerprop{basey}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@edgepointy}%
          \corasdiagram@setgroupedmarkerprop{finalpos}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@groupedgecenterpos}%
          \corasdiagram@setgroupedmarkerprop{densemode}{\the\corasdiagram@groupedmarkerindex}{\corasdiagram@groupedgedensemode}%
          \ifnum\corasdiagram@groupedgedensemode=1\relax
          \else
            \pgfmathsetmacro{\corasdiagram@groupedgecurrentleftpt}{\corasdiagram@groupedgecenterpt + \corasdiagram@groupedmarkerhalfspanpt + \corasdiagram@groupedgeintergappt}%
          \fi
        \fi
      \fi
      \advance\corasdiagram@groupedmarkerindex by 1\relax
    }%
  \fi
}

