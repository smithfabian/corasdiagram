      \def\corasdiagram@typedordersettled{0}%
      \@whilenum\corasdiagram@typedordersettled=0\relax\do{%
        \corasdiagram@getroleordernode{\corasdiagram@typedexistingordernode}{\corasnode@role}{\corasdiagram@typedcandidateorder}%
        \ifx\corasdiagram@typedexistingordernode\@empty
          \edef\corasnode@order{\corasdiagram@typedcandidateorder}%
          \def\corasdiagram@typedordersettled{1}%
        \else
          \pgfmathtruncatemacro{\corasdiagram@typedcandidateorder}{\corasdiagram@typedcandidateorder + 1}%
        \fi
      }%
    \fi
  \fi
}

