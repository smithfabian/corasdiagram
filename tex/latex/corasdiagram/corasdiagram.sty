  \pgfmathsetmacro{\corasdiagram@edgepointy}{\corasdiagram@edgefromy + (#1)*\corasdiagram@edgedy}%
}

\newcommand{\corasdiagram@computeedgeboxhalfspanfromptnums}[2]{%
  \pgfmathsetmacro{\corasdiagram@edgeboxhalfspan}{0}%
  \pgfmathparse{abs(\corasdiagram@edgelen) > 0.01 ? 1 : 0}%
  \ifnum\pgfmathresult=1\relax
    \pgfmathsetmacro{\corasdiagram@edgeboxhalfspan}{0.5*((abs(\corasdiagram@edgedx)/\corasdiagram@edgelen)*(#1) + (abs(\corasdiagram@edgedy)/\corasdiagram@edgelen)*(#2))}%
  \fi
}

\newcommand{\corasdiagram@computeedgeboxhalfspanfromdims}[2]{%
  \ifx#1\@empty
    \pgfmathsetmacro{\corasdiagram@edgeboxhalfspan}{0}%
  \else
    \corasdiagram@tmpdimen=#1\relax
    \edef\corasdiagram@boxwidthpt{\strip@pt\corasdiagram@tmpdimen}%
    \corasdiagram@tmpdimen=#2\relax
    \edef\corasdiagram@boxheightpt{\strip@pt\corasdiagram@tmpdimen}%
    \corasdiagram@computeedgeboxhalfspanfromptnums{\corasdiagram@boxwidthpt}{\corasdiagram@boxheightpt}%
  \fi
}

