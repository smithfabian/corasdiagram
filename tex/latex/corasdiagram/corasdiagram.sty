}

\newcommand{\corasdiagram@resolvedgesemantic}{%
  \ifx\corasedge@semantic\@empty
    \edef\corasedge@semantic{\corasedge@type}%
    \def\corasdiagram@overview{overview}%
    \ifx\corasedge@semantic\corasdiagram@overview
      \def\corasedge@semantic{treatment}%
    \fi
  \fi
}

\newcommand{\corasdiagram@validateedgeannotations}{%
  \ifx\corasedge@annotationvalidated\@empty
    \def\corasedge@annotationvalidated{0}%
  \fi
  \ifnum\corasedge@annotationvalidated=1\relax
    \expandafter\@gobble
  \else
    \expandafter\@firstofone
  \fi
  {%
  \ifx\corasedge@removedprobability\@empty
  \else
    \PackageError{corasdiagram}{Edge key `probability` has been removed}{%
      Use `conditional likelihood=<text>` on \string\leadsto\space edges.%
    }%
  \fi
  \ifx\corasedge@removedvia\@empty
  \else
    \PackageError{corasdiagram}{Edge key `via` has been removed}{%
      Use `vulnerability={...}` on \string\initiates\space edges.%
    }%
  \fi
  \ifx\corasedge@removedhasvulnerability\@empty
  \else
    \PackageError{corasdiagram}{Edge key `has_vulnerability` has been removed}{%
      Use `vulnerability={...}` on \string\initiates\space edges.%
    }%
  \fi
  \ifx\corasedge@probability\@empty
  \else
    \ifx\corasedge@consequence\@empty
    \else
      \PackageError{corasdiagram}{Use only one semantic edge annotation key per edge}{%
        Use at most one of `conditional likelihood`, `consequence`, `asset value`, or `treatment category` on the same edge.%
      }%
    \fi
    \ifx\corasedge@label\@empty
    \else
      \PackageError{corasdiagram}{`conditional likelihood` cannot be combined with `label`}{%
        Use `conditional likelihood=<text>` on \string\leadsto\space edges instead of `label=...`.%
      }%
    \fi
    \corasdiagram@ifleadstosemantic{\corasedge@semantic}{}{%
      \PackageError{corasdiagram}{`conditional likelihood` is only valid on leads-to edges}{%
        Use `conditional likelihood=<text>` with \string\leadsto\space edges.%
      }%
    }%
    \expandafter\def\expandafter\corasedge@label\expandafter{\corasedge@probability}%
  \fi
  \ifx\corasedge@consequence\@empty
  \else
    \ifx\corasedge@label\@empty
    \else
      \PackageError{corasdiagram}{`consequence` cannot be combined with `label`}{%
        Use `consequence=<text>` on \string\impacts\space edges instead of `label=...`.%
      }%
    \fi
    \corasdiagram@ifincsv{\corasedge@semantic}{relation,impacts}{}{%
      \PackageError{corasdiagram}{`consequence` is only valid on impacts edges}{%
        Use `consequence=<text>` with \string\impacts\space edges.%
      }%
    }%
    \expandafter\def\expandafter\corasedge@label\expandafter{\corasedge@consequence}%
  \fi
  \ifx\corasedge@assetvalue\@empty
  \else
    \ifx\corasedge@label\@empty
    \else
      \PackageError{corasdiagram}{`asset value` cannot be combined with `label`}{%
        Use `asset value=<text>` on \string\assigns\space edges instead of `label=...`.%
      }%
    \fi
    \corasdiagram@ifassignssemantic{\corasedge@semantic}{}{%
      \PackageError{corasdiagram}{`asset value` is only valid on assigns edges}{%
        Use `asset value=<text>` with \string\assigns\space edges.%
      }%
    }%
    \expandafter\def\expandafter\corasedge@label\expandafter{\corasedge@assetvalue}%
  \fi
  \ifx\corasedge@treatmentcategory\@empty
  \else
    \ifx\corasedge@label\@empty
    \else
      \PackageError{corasdiagram}{`treatment category` cannot be combined with `label`}{%
        Use `treatment category=<text>` on \string\treats\space edges instead of `label=...`.%
      }%
    \fi
    \corasdiagram@iftreatssemantic{\corasedge@semantic}{}{%
      \PackageError{corasdiagram}{`treatment category` is only valid on treats edges}{%
        Use `treatment category=<text>` with \string\treats\space edges.%
      }%
    }%
    \expandafter\def\expandafter\corasedge@label\expandafter{\corasedge@treatmentcategory}%
  \fi
  \def\corasedge@annotationvalidated{1}%
  }%
}

\newcommand{\corasdiagram@validategroupedvulnerabilities}{%
  \ifx\corasedge@hasvulnerability\@empty
  \else
    \corasdiagram@ifinitiatessemantic{\corasedge@semantic}{}{%
      \PackageError{corasdiagram}{`vulnerability` is only valid on initiates edges}{%
        Use `vulnerability={...}` with \string\initiates\space edges.%
      }%
    }%
    \ifnum\corasdiagram@fromlistcount=1\relax
    \else
      \PackageError{corasdiagram}{`vulnerability` cannot be combined with a list-valued `from=`}{%
        Use a single `from=<node>` together with `vulnerability={v1,v2,...}`.%
      }%
    \fi
    \ifnum\corasdiagram@tolistcount=1\relax
    \else
      \PackageError{corasdiagram}{`vulnerability` cannot be combined with a list-valued `to=`}{%
        Use a single `to=<node>` together with `vulnerability={v1,v2,...}`.%
      }%
    \fi
    \corasdiagram@parsecsvstoredvalue{\corasedge@hasvulnerability}{\corasdiagram@validatedvulnlist}{\corasdiagram@validatedvulncount}%
    \ifnum\corasdiagram@validatedvulncount>0\relax
    \else
      \PackageError{corasdiagram}{`vulnerability` requires one or more vulnerability items}{%
        Provide `vulnerability={unpatched_system,poor_security_design}` or inline text items.%
      }%
    \fi
    \@for\corasdiagram@groupedvuln:=\corasdiagram@validatedvulnlist\do{%
      \corasdiagram@lookupendpointrole{\corasdiagram@groupedvulnrole}{\corasdiagram@groupedvuln}%
      \ifx\corasdiagram@groupedvulnrole\@empty
        \PackageError{corasdiagram}{Unknown node `\corasdiagram@groupedvuln' in `vulnerability`}{%
          Declare each grouped vulnerability node before using it on an initiates edge.%
        }%
      \else
        \def\corasdiagram@vulnerabilityrole{vulnerability}%
        \ifx\corasdiagram@groupedvulnrole\corasdiagram@vulnerabilityrole
        \else
          \PackageError{corasdiagram}{Node `\corasdiagram@groupedvuln' in `vulnerability` is not a vulnerability}{%
            Use only declared \string\vulnerability\space node names in `vulnerability={...}`.%
          }%
        \fi
      \fi
    }%
    \edef\corasedge@hasvulnerability{\corasdiagram@validatedvulnlist}%
  \fi
}

\newcommand{\corasdiagram@defaultpathforroute}{%
  \def\corasdiagram@edgepath{--}%
  \def\corasdiagram@routeauto{auto}%
  \def\corasdiagram@routestraight{straight}%
  \def\corasdiagram@routehv{hv}%
  \def\corasdiagram@routevh{vh}%
  \ifx\corasedge@route\corasdiagram@routehv
    \def\corasdiagram@edgepath{-|}%
  \else\ifx\corasedge@route\corasdiagram@routevh
    \def\corasdiagram@edgepath{|-}%
  \else\ifx\corasedge@route\corasdiagram@routestraight
    \def\corasdiagram@edgepath{--}%
  \else
    \def\corasdiagram@edgepath{--}%
    \corasdiagram@ifassignssemantic{\corasedge@semantic}{%
      \def\corasdiagram@edgepath{-|}%
    }{%
      \corasdiagram@iftreatssemantic{\corasedge@semantic}{%
        \def\corasdiagram@edgepath{--}%
      }{}%
    }%
  \fi\fi\fi
}

\newcommand{\corasdiagram@setcurveanchorsfromdelta}{%
  \pgfmathtruncatemacro{\corasdiagram@verticaldominant}{abs(\corasdiagram@dy) > abs(\corasdiagram@dx) ? 1 : 0}%
  \ifnum\corasdiagram@verticaldominant=1\relax
    \pgfmathtruncatemacro{\corasdiagram@targetabove}{\corasdiagram@dy > 0 ? 1 : 0}%
    \ifnum\corasdiagram@targetabove=1\relax
      \xdef\corasdiagram@fromanchorsuffix{north}%
      \xdef\corasdiagram@toanchorsuffix{south}%
      \xdef\corasdiagram@curveout{90}%
      \xdef\corasdiagram@curvein{-90}%
    \else
      \xdef\corasdiagram@fromanchorsuffix{south}%
      \xdef\corasdiagram@toanchorsuffix{north}%
      \xdef\corasdiagram@curveout{-90}%
      \xdef\corasdiagram@curvein{90}%
    \fi
  \else
    \pgfmathtruncatemacro{\corasdiagram@targetright}{\corasdiagram@dx > 0 ? 1 : 0}%
    \ifnum\corasdiagram@targetright=1\relax
      \xdef\corasdiagram@fromanchorsuffix{east}%
      \xdef\corasdiagram@toanchorsuffix{west}%
      \xdef\corasdiagram@curveout{0}%
      \xdef\corasdiagram@curvein{180}%
    \else
      \xdef\corasdiagram@fromanchorsuffix{west}%
      \xdef\corasdiagram@toanchorsuffix{east}%
      \xdef\corasdiagram@curveout{180}%
      \xdef\corasdiagram@curvein{0}%
    \fi
  \fi
}

\newcommand{\corasdiagram@newedgecoordname}[1]{%
  \global\advance\corasdiagram@edgecoordseq by 1\relax
  \edef#1{coras-edge-\the\corasdiagram@edgecoordseq}%
}

\newcommand{\corasdiagram@markbordereligible}[3]{%
  \corasdiagram@endpointbasename{#2}{#1}%
  \def#3{0}%
  \ifx#2\@empty
  \else
    \edef\corasdiagram@rawplain{#1}%
    \edef\corasdiagram@baseplain{#2}%
    \ifx\corasdiagram@rawplain\corasdiagram@baseplain
      \corasdiagram@getbordernode{\corasdiagram@lookupbordernode}{#2}%
      \ifx\corasdiagram@lookupbordernode\@empty
      \else
        \def#3{1}%
      \fi
    \fi
  \fi
}

\newcommand{\corasdiagram@makeedgecoord}[2]{%
  \path coordinate (#1) at #2;
}

\newcommand{\corasdiagram@setsnappeddirectionalanchor}{%
  \pgfmathtruncatemacro{\corasdiagram@zerodelta}{abs(\corasdiagram@dx) < 0.02 && abs(\corasdiagram@dy) < 0.02 ? 1 : 0}%
  \ifnum\corasdiagram@zerodelta=1\relax
    \xdef\corasdiagram@snappeddirectionalanchor{north}%
  \else
    \pgfmathsetmacro{\corasdiagram@borderangle}{atan2(\corasdiagram@dy,\corasdiagram@dx)}%
    \ifdim\corasdiagram@borderangle pt>157.5pt\relax
      \xdef\corasdiagram@snappeddirectionalanchor{west}%
    \else\ifdim\corasdiagram@borderangle pt>112.5pt\relax
      \xdef\corasdiagram@snappeddirectionalanchor{northwest}%
    \else\ifdim\corasdiagram@borderangle pt>67.5pt\relax
      \xdef\corasdiagram@snappeddirectionalanchor{north}%
    \else\ifdim\corasdiagram@borderangle pt>22.5pt\relax
      \xdef\corasdiagram@snappeddirectionalanchor{northeast}%
    \else\ifdim\corasdiagram@borderangle pt>-22.5pt\relax
      \xdef\corasdiagram@snappeddirectionalanchor{east}%
    \else\ifdim\corasdiagram@borderangle pt>-67.5pt\relax
      \xdef\corasdiagram@snappeddirectionalanchor{southeast}%
    \else\ifdim\corasdiagram@borderangle pt>-112.5pt\relax
      \xdef\corasdiagram@snappeddirectionalanchor{south}%
    \else
      \ifdim\corasdiagram@borderangle pt>-157.5pt\relax
        \xdef\corasdiagram@snappeddirectionalanchor{southwest}%
      \else
        \xdef\corasdiagram@snappeddirectionalanchor{west}%
      \fi
    \fi\fi\fi\fi\fi\fi\fi
  \fi
}

\newcommand{\corasdiagram@getnodeanchorname}[2]{%
  \expandafter\ifx\csname corasdiagram@nodeanchorname@#2\endcsname\relax
    \edef#1{west}%
  \else
    \edef#1{\csname corasdiagram@nodeanchorname@#2\endcsname}%
  \fi
}
\expandafter\def\csname corasdiagram@nodeanchorname@north\endcsname{north}
\expandafter\def\csname corasdiagram@nodeanchorname@northeast\endcsname{north east}
\expandafter\def\csname corasdiagram@nodeanchorname@east\endcsname{east}
\expandafter\def\csname corasdiagram@nodeanchorname@southeast\endcsname{south east}
\expandafter\def\csname corasdiagram@nodeanchorname@south\endcsname{south}
\expandafter\def\csname corasdiagram@nodeanchorname@southwest\endcsname{south west}
\expandafter\def\csname corasdiagram@nodeanchorname@west\endcsname{west}
\expandafter\def\csname corasdiagram@nodeanchorname@northwest\endcsname{north west}

\newcommand{\corasdiagram@makeiconbordercoord}[3]{%
  \corasdiagram@getbordernode{\corasdiagram@bordernodename}{#1}%
  \path let \p1=(\corasdiagram@bordernodename.center), \p2=(#2.center) in \pgfextra{%
    \pgfmathsetmacro{\corasdiagram@dx}{\x2-\x1}%
    \pgfmathsetmacro{\corasdiagram@dy}{\y2-\y1}%
    \corasdiagram@setsnappeddirectionalanchor
  };%
  \corasdiagram@getnodeanchorname{\corasdiagram@nodeanchorname}{\corasdiagram@snappeddirectionalanchor}%
  \pgf@process{\pgfpointanchor{\corasdiagram@bordernodename}{\corasdiagram@nodeanchorname}}%
  \edef\corasdiagram@borderx{\the\pgf@x}%
  \edef\corasdiagram@bordery{\the\pgf@y}%
  \path coordinate (#3) at (\corasdiagram@borderx,\corasdiagram@bordery);
}

\newcommand{\corasdiagram@makebordercoord}[3]{%
  \corasdiagram@getnodeprop{anchorsymbol}{#1}{\corasdiagram@bordersymbol}%
  \ifx\corasdiagram@bordersymbol\@empty
    \corasdiagram@getbordernode{\corasdiagram@bordernodename}{#1}%
    \edef\corasdiagram@borderrefname{#2}%
    \pgf@process{%
      \expandafter\pgfpointshapeborder\expandafter{\corasdiagram@bordernodename}{%
        \expandafter\pgfpointanchor\expandafter{\corasdiagram@borderrefname}{center}%
      }%
    }%
    \edef\corasdiagram@borderx{\the\pgf@x}%
    \edef\corasdiagram@bordery{\the\pgf@y}%
    \path coordinate (#3) at (\corasdiagram@borderx,\corasdiagram@bordery);
  \else
    \corasdiagram@makeiconbordercoord{#1}{#2}{#3}%
  \fi
}

\newcommand{\corasdiagram@applyexactborderanchors}{%
  \ifx\corasedge@path\@empty
    \corasdiagram@markbordereligible{\corasedge@rawfrom}{\corasdiagram@linefrombase}{\corasdiagram@applyfrom}%
    \corasdiagram@markbordereligible{\corasedge@rawto}{\corasdiagram@linetobase}{\corasdiagram@applyto}%
    \ifnum\corasdiagram@applyfrom=1\relax
      \def\corasdiagram@applyanchors{1}%
    \else\ifnum\corasdiagram@applyto=1\relax
      \def\corasdiagram@applyanchors{1}%
    \else
      \def\corasdiagram@applyanchors{0}%
    \fi\fi
    \ifnum\corasdiagram@applyanchors=1\relax
      \corasdiagram@newedgecoordname{\corasdiagram@actualfromcoord}%
      \corasdiagram@newedgecoordname{\corasdiagram@actualtocoord}%
      \corasdiagram@makeedgecoord{\corasdiagram@actualfromcoord}{(\corasedge@from)}%
      \corasdiagram@makeedgecoord{\corasdiagram@actualtocoord}{(\corasedge@to)}%
      \edef\corasdiagram@fromrefcoord{\corasdiagram@actualtocoord}%
      \edef\corasdiagram@torefcoord{\corasdiagram@actualfromcoord}%
      \def\corasdiagram@edgepathhv{-|}%
      \def\corasdiagram@edgepathvh{|-}%
      \ifx\corasdiagram@edgepath\corasdiagram@edgepathhv
        \corasdiagram@newedgecoordname{\corasdiagram@elbowcoord}%
        \corasdiagram@makeedgecoord{\corasdiagram@elbowcoord}{(\corasedge@from -| \corasedge@to)}%
        \edef\corasdiagram@fromrefcoord{\corasdiagram@elbowcoord}%
        \edef\corasdiagram@torefcoord{\corasdiagram@elbowcoord}%
      \else\ifx\corasdiagram@edgepath\corasdiagram@edgepathvh
        \corasdiagram@newedgecoordname{\corasdiagram@elbowcoord}%
        \corasdiagram@makeedgecoord{\corasdiagram@elbowcoord}{(\corasedge@from |- \corasedge@to)}%
        \edef\corasdiagram@fromrefcoord{\corasdiagram@elbowcoord}%
        \edef\corasdiagram@torefcoord{\corasdiagram@elbowcoord}%
      \fi\fi
      \ifnum\corasdiagram@applyfrom=1\relax
        \corasdiagram@newedgecoordname{\corasdiagram@frombordercoord}%
        \corasdiagram@makebordercoord{\corasdiagram@linefrombase}{\corasdiagram@fromrefcoord}{\corasdiagram@frombordercoord}%
        \edef\corasedge@from{\corasdiagram@frombordercoord}%
      \fi
      \ifnum\corasdiagram@applyto=1\relax
        \corasdiagram@newedgecoordname{\corasdiagram@tobordercoord}%
        \corasdiagram@makebordercoord{\corasdiagram@linetobase}{\corasdiagram@torefcoord}{\corasdiagram@tobordercoord}%
        \edef\corasedge@to{\corasdiagram@tobordercoord}%
      \fi
    \fi
  \fi
}

\newcommand{\corasdiagram@drawcurvededge}{%
  \corasdiagram@markbordereligible{\corasedge@rawfrom}{\corasdiagram@curvefrombase}{\corasdiagram@applycurvefrom}%
  \corasdiagram@markbordereligible{\corasedge@rawto}{\corasdiagram@curvetobase}{\corasdiagram@applycurveto}%
  \ifx\corasdiagram@curvefrombase\@empty
    \def\corasdiagram@curveavailable{0}%
  \else\ifx\corasdiagram@curvetobase\@empty
    \def\corasdiagram@curveavailable{0}%
  \else
    \def\corasdiagram@curveavailable{1}%
  \fi\fi
  \ifnum\corasdiagram@curveavailable=1\relax
    \corasdiagram@newedgecoordname{\corasdiagram@curvefromcenter}%
    \corasdiagram@newedgecoordname{\corasdiagram@curvetocenter}%
    \corasdiagram@makeedgecoord{\corasdiagram@curvefromcenter}{(\corasedge@from)}%
    \corasdiagram@makeedgecoord{\corasdiagram@curvetocenter}{(\corasedge@to)}%
    \path let \p1=(\corasdiagram@curvefromcenter), \p2=(\corasdiagram@curvetocenter) in \pgfextra{%
      \pgfmathsetmacro{\corasdiagram@dx}{\x2-\x1}%
      \pgfmathsetmacro{\corasdiagram@dy}{\y2-\y1}%
      \corasdiagram@setcurveanchorsfromdelta
    };
    \corasdiagram@newedgecoordname{\corasdiagram@curvefirstcontrol}%
    \corasdiagram@newedgecoordname{\corasdiagram@curvesecondcontrol}%
    \corasdiagram@newedgecoordname{\corasdiagram@curvefirstborderref}%
    \corasdiagram@newedgecoordname{\corasdiagram@curvesecondborderref}%
    \corasdiagram@makeedgecoord{\corasdiagram@curvefirstcontrol}{($(\corasdiagram@curvefromcenter)+(\corasdiagram@curveout:8mm)$)}%
    \corasdiagram@makeedgecoord{\corasdiagram@curvesecondcontrol}{($(\corasdiagram@curvetocenter)+(\corasdiagram@curvein:8mm)$)}%
    \corasdiagram@makeedgecoord{\corasdiagram@curvefirstborderref}{($(\corasdiagram@curvefromcenter)+(\corasdiagram@curveout:40mm)$)}%
    \corasdiagram@makeedgecoord{\corasdiagram@curvesecondborderref}{($(\corasdiagram@curvetocenter)+(\corasdiagram@curvein:40mm)$)}%
    \edef\corasdiagram@curvefrom{\corasedge@from}%
    \edef\corasdiagram@curveto{\corasedge@to}%
    \ifnum\corasdiagram@applycurvefrom=1\relax
      \corasdiagram@newedgecoordname{\corasdiagram@curvefromborder}%
      \corasdiagram@makebordercoord{\corasdiagram@curvefrombase}{\corasdiagram@curvefirstborderref}{\corasdiagram@curvefromborder}%
      \edef\corasdiagram@curvefrom{\corasdiagram@curvefromborder}%
    \fi
    \ifnum\corasdiagram@applycurveto=1\relax
      \corasdiagram@newedgecoordname{\corasdiagram@curvetoborder}%
      \corasdiagram@makebordercoord{\corasdiagram@curvetobase}{\corasdiagram@curvesecondborderref}{\corasdiagram@curvetoborder}%
      \edef\corasdiagram@curveto{\corasdiagram@curvetoborder}%
    \fi
    \ifx\corasedge@label\@empty
      \expandafter\draw\expandafter[\corasdiagram@edgeoptions]
        (\corasdiagram@curvefrom)
        .. controls (\corasdiagram@curvefirstcontrol) and (\corasdiagram@curvesecondcontrol) ..
        (\corasdiagram@curveto);
    \else
      \edef\corasdiagram@edgelabelfragment{%
        node[\corasdiagram@edgelabeloptions]{%
          \unexpanded\expandafter{\corasedge@label}%
        }%
      }%
      \expandafter\draw\expandafter[\corasdiagram@edgeoptions]
        (\corasdiagram@curvefrom)
        .. controls (\corasdiagram@curvefirstcontrol) and (\corasdiagram@curvesecondcontrol) ..
        \corasdiagram@edgelabelfragment
        (\corasdiagram@curveto);
    \fi
  \else
    \ifx\corasedge@label\@empty
      \expandafter\draw\expandafter[\corasdiagram@edgeoptions]
        (\corasedge@from) \corasdiagram@edgepath (\corasedge@to);
    \else
      \edef\corasdiagram@edgelabelfragment{%
        node[\corasdiagram@edgelabeloptions]{%
          \unexpanded\expandafter{\corasedge@label}%
        }%
      }%
      \expandafter\draw\expandafter[\corasdiagram@edgeoptions]
        (\corasedge@from) \corasdiagram@edgepath (\corasedge@to)
        \corasdiagram@edgelabelfragment;
    \fi
  \fi
}

\newcommand{\corasdiagram@resolverenderededgepos}{%
  \edef\corasdiagram@resolvededgepos{\corasedge@pos}%
  \def\corasdiagram@threatfamily{threat}%
  \def\corasdiagram@treatmentfamily{treatment}%
  \corasdiagram@ifcausalflowsemantic{\corasedge@semantic}{%
    \ifx\corasedge@probability\@empty
    \else
      \ifx\corasedge@posexplicit\@empty
        \def\corasedge@posexplicit{0}%
      \fi
      \ifnum\corasedge@posexplicit=0\relax
        \ifx\corasdiagram@currentfamily\corasdiagram@threatfamily
          \def\corasdiagram@resolvededgepos{0.18}%
        \else\ifx\corasdiagram@currentfamily\corasdiagram@treatmentfamily
          \def\corasdiagram@resolvededgepos{0.18}%
        \fi\fi
      \fi
    \fi
  }{}%
}

\newcommand{\corasdiagram@preparecurrentedge}{%
  \corasdiagram@resolveendpoint{\corasedge@from}%
  \edef\corasedge@from{\corasdiagram@resolvedendpoint}%
  \corasdiagram@resolveendpoint{\corasedge@to}%
  \edef\corasedge@to{\corasdiagram@resolvedendpoint}%
  \ifx\corasedge@path\@empty
    \corasdiagram@defaultpathforroute
  \else
    \edef\corasdiagram@edgepath{\corasedge@path}%
  \fi
  \corasdiagram@applyexactborderanchors
  \corasdiagram@resolverenderededgepos
  \edef\corasdiagram@edgeoptions{coras/\corasedge@type,\corasedge@tikz}%
  \edef\corasdiagram@edgelabeloptions{pos=\corasdiagram@resolvededgepos,\corasedge@labeloptions}%
}

\newcommand{\corasdiagram@drawtreatslabelnode}{%
  \ifx\corasedge@label\@empty
  \else
    \edef\corasdiagram@treatlabeloptions{coras/base node,\corasedge@labeloptions}%
    \expandafter\node\expandafter[\corasdiagram@treatlabeloptions]
      at ($ (\corasedge@from)!\corasdiagram@resolvededgepos!(\corasedge@to) $) {%
        \unexpanded\expandafter{\corasedge@label}%
      };
  \fi
}

\newcommand{\corasdiagram@drawpreparededge}{%
  \corasdiagram@iftreatssemantic{\corasedge@semantic}{%
    \edef\corasdiagram@treatsavedlabel{\corasedge@label}%
    \let\corasedge@label\@empty
    \ifx\corasedge@path\@empty
      \corasdiagram@drawcurvededge
    \else
      \expandafter\draw\expandafter[\corasdiagram@edgeoptions]
        (\corasedge@from) \corasdiagram@edgepath (\corasedge@to);
    \fi
    \edef\corasedge@label{\corasdiagram@treatsavedlabel}%
    \corasdiagram@drawtreatslabelnode
  }{%
    \ifx\corasedge@label\@empty
      \expandafter\draw\expandafter[\corasdiagram@edgeoptions]
        (\corasedge@from) \corasdiagram@edgepath (\corasedge@to);
    \else
      \edef\corasdiagram@edgelabelfragment{%
        node[\corasdiagram@edgelabeloptions]{%
          \unexpanded\expandafter{\corasedge@label}%
        }%
      }%
      \expandafter\draw\expandafter[\corasdiagram@edgeoptions]
        (\corasedge@from) \corasdiagram@edgepath (\corasedge@to)
        \corasdiagram@edgelabelfragment;
    \fi
  }%
}

\newcommand{\corasdiagram@markvulnerabilityexternalusage}{%
  \def\corasdiagram@threatfamily{threat}%
  \def\corasdiagram@treatmentfamily{treatment}%
  \def\corasdiagram@vulnerabilityrole{vulnerability}%
  \ifx\corasdiagram@currentfamily\corasdiagram@threatfamily
    \ifx\corasedge@fromrole\corasdiagram@vulnerabilityrole
      \corasdiagram@endpointbasename{\corasdiagram@edgebase}{\corasedge@rawfrom}%
      \corasdiagram@setnodeprop{externaledge}{\corasdiagram@edgebase}{1}%
    \fi
    \ifx\corasedge@torole\corasdiagram@vulnerabilityrole
      \corasdiagram@endpointbasename{\corasdiagram@edgebase}{\corasedge@rawto}%
      \corasdiagram@setnodeprop{externaledge}{\corasdiagram@edgebase}{1}%
    \fi
  \else\ifx\corasdiagram@currentfamily\corasdiagram@treatmentfamily
    \ifx\corasedge@fromrole\corasdiagram@vulnerabilityrole
      \corasdiagram@endpointbasename{\corasdiagram@edgebase}{\corasedge@rawfrom}%
      \corasdiagram@setnodeprop{externaledge}{\corasdiagram@edgebase}{1}%
    \fi
    \ifx\corasedge@torole\corasdiagram@vulnerabilityrole
      \corasdiagram@endpointbasename{\corasdiagram@edgebase}{\corasedge@rawto}%
      \corasdiagram@setnodeprop{externaledge}{\corasdiagram@edgebase}{1}%
    \fi
  \fi\fi
}

\newcommand{\corasdiagram@currentedgeisdefereligible}{%
  \def\corasdiagram@deferedge{0}%
  \def\corasdiagram@threatfamily{threat}%
  \def\corasdiagram@riskfamily{risk}%
  \def\corasdiagram@treatmentfamily{treatment}%
  \corasdiagram@ifcausalflowsemantic{\corasedge@semantic}{%
    \ifx\corasdiagram@currentfamily\corasdiagram@threatfamily
      \ifx\corasedge@fromrole\@empty
      \else\ifx\corasedge@torole\@empty
      \else
        \def\corasdiagram@deferedge{1}%
      \fi\fi
    \else\ifx\corasdiagram@currentfamily\corasdiagram@treatmentfamily
      \ifx\corasedge@fromrole\@empty
      \else\ifx\corasedge@torole\@empty
      \else
        \def\corasdiagram@deferedge{1}%
      \fi\fi
    \else\ifx\corasdiagram@currentfamily\corasdiagram@riskfamily
      \ifx\corasedge@fromrole\@empty
      \else\ifx\corasedge@torole\@empty
      \else
        \def\corasdiagram@deferedge{1}%
      \fi\fi
    \fi\fi\fi
  }{}%
}

\newcommand{\corasdiagram@currentedgeiscompressible}{%
  \def\corasdiagram@edgecompressible{1}%
  \def\corasdiagram@routeauto{auto}%
  \def\corasdiagram@causaltype{causal}%
  \corasdiagram@ifcausalflowsemantic{\corasedge@semantic}{}{%
    \def\corasdiagram@edgecompressible{0}%
  }%
  \ifx\corasedge@type\corasdiagram@causaltype
  \else
    \def\corasdiagram@edgecompressible{0}%
  \fi
  \ifx\corasedge@path\@empty
  \else
    \def\corasdiagram@edgecompressible{0}%
  \fi
  \ifx\corasedge@tikz\@empty
  \else
    \def\corasdiagram@edgecompressible{0}%
  \fi
  \ifx\corasedge@label\@empty
  \else
    \def\corasdiagram@edgecompressible{0}%
  \fi
  \ifx\corasedge@route\corasdiagram@routeauto
  \else
    \def\corasdiagram@edgecompressible{0}%
  \fi
  \ifx\corasedge@fromrole\@empty
    \def\corasdiagram@edgecompressible{0}%
  \fi
  \ifx\corasedge@torole\@empty
    \def\corasdiagram@edgecompressible{0}%
  \fi
  \ifx\corasedge@hasvulnerability\@empty
  \else
    \def\corasdiagram@edgecompressible{0}%
  \fi
}

\newcommand{\corasdiagram@storecurrentedge}{%
  \global\advance\corasdiagram@pendingedgecount by 1\relax
  \edef\corasdiagram@storededgeid{\the\corasdiagram@pendingedgecount}%
  \corasdiagram@endpointbasename{\corasdiagram@storedfrombase}{\corasedge@rawfrom}%
  \corasdiagram@endpointbasename{\corasdiagram@storedtobase}{\corasedge@rawto}%
  \corasdiagram@currentedgeiscompressible
  \corasdiagram@setedgeprop{rawfrom}{\corasdiagram@storededgeid}{\corasedge@rawfrom}%
  \corasdiagram@setedgeprop{rawto}{\corasdiagram@storededgeid}{\corasedge@rawto}%
  \corasdiagram@setedgeprop{frombase}{\corasdiagram@storededgeid}{\corasdiagram@storedfrombase}%
  \corasdiagram@setedgeprop{tobase}{\corasdiagram@storededgeid}{\corasdiagram@storedtobase}%
  \corasdiagram@setedgeprop{fromrole}{\corasdiagram@storededgeid}{\corasedge@fromrole}%
  \corasdiagram@setedgeprop{torole}{\corasdiagram@storededgeid}{\corasedge@torole}%
  \corasdiagram@setedgeprop{type}{\corasdiagram@storededgeid}{\corasedge@type}%
  \corasdiagram@setedgeprop{semantic}{\corasdiagram@storededgeid}{\corasedge@semantic}%
  \corasdiagram@setedgeprop{label}{\corasdiagram@storededgeid}{\corasedge@label}%
  \corasdiagram@setedgeprop{probability}{\corasdiagram@storededgeid}{\corasedge@probability}%
  \corasdiagram@setedgeprop{consequence}{\corasdiagram@storededgeid}{\corasedge@consequence}%
  \corasdiagram@setedgeprop{annotationvalidated}{\corasdiagram@storededgeid}{\corasedge@annotationvalidated}%
  \corasdiagram@setedgeprop{pos}{\corasdiagram@storededgeid}{\corasedge@pos}%
  \corasdiagram@setedgeprop{posexplicit}{\corasdiagram@storededgeid}{\corasedge@posexplicit}%
  \corasdiagram@setedgeprop{path}{\corasdiagram@storededgeid}{\corasedge@path}%
  \corasdiagram@setedgeprop{route}{\corasdiagram@storededgeid}{\corasedge@route}%
  \corasdiagram@setedgeprop{tikz}{\corasdiagram@storededgeid}{\corasedge@tikz}%
  \corasdiagram@setedgeprop{labeloptions}{\corasdiagram@storededgeid}{\corasedge@labeloptions}%
  \ifx\corasedge@hasvulnerability\@empty
    \corasdiagram@setedgeprop{groupedvulnerabilities}{\corasdiagram@storededgeid}{}%
    \corasdiagram@setedgeprop{groupedmode}{\corasdiagram@storededgeid}{0}%
  \else
    \corasdiagram@setedgeprop{groupedvulnerabilities}{\corasdiagram@storededgeid}{\corasedge@hasvulnerability}%
    \corasdiagram@setedgeprop{groupedmode}{\corasdiagram@storededgeid}{1}%
  \fi
  \corasdiagram@setedgeprop{compressible}{\corasdiagram@storededgeid}{\corasdiagram@edgecompressible}%
  \corasdiagram@setedgeprop{consumed}{\corasdiagram@storededgeid}{0}%
}

\newcommand{\corasdiagram@loadstorededge}[1]{%
  \corasdiagram@getedgeprop{rawfrom}{#1}{\corasedge@from}%
  \corasdiagram@getedgeprop{rawto}{#1}{\corasedge@to}%
  \edef\corasedge@rawfrom{\corasedge@from}%
  \edef\corasedge@rawto{\corasedge@to}%
  \corasdiagram@getedgeprop{type}{#1}{\corasedge@type}%
  \corasdiagram@getedgeprop{semantic}{#1}{\corasedge@semantic}%
  \corasdiagram@getedgeprop{label}{#1}{\corasedge@label}%
  \corasdiagram@getedgeprop{probability}{#1}{\corasedge@probability}%
  \corasdiagram@getedgeprop{consequence}{#1}{\corasedge@consequence}%
  \corasdiagram@getedgeprop{annotationvalidated}{#1}{\corasedge@annotationvalidated}%
  \corasdiagram@getedgeprop{pos}{#1}{\corasedge@pos}%
  \corasdiagram@getedgeprop{posexplicit}{#1}{\corasedge@posexplicit}%
  \corasdiagram@getedgeprop{path}{#1}{\corasedge@path}%
  \corasdiagram@getedgeprop{route}{#1}{\corasedge@route}%
  \corasdiagram@getedgeprop{tikz}{#1}{\corasedge@tikz}%
  \corasdiagram@getedgeprop{labeloptions}{#1}{\corasedge@labeloptions}%
  \corasdiagram@getedgeprop{fromrole}{#1}{\corasedge@fromrole}%
  \corasdiagram@getedgeprop{torole}{#1}{\corasedge@torole}%
}

\newcommand{\corasdiagram@drawstorededge}[1]{%
  \corasdiagram@loadstorededge{#1}%
  \corasdiagram@preparecurrentedge
  \corasdiagram@drawpreparededge
}

\newcommand{\corasdiagram@initializevulnerabilitychainstate}{%
  \corasdiagram@placedindex=1\relax
  \loop
    \ifnum\corasdiagram@placedindex<\numexpr\corasdiagram@placedcount+1\relax
      \corasdiagram@getplacednode{\corasdiagram@currentplacednode}{\the\corasdiagram@placedindex}%
      \ifx\corasdiagram@currentplacednode\@empty
      \else
        \corasdiagram@getnodeprop{type}{\corasdiagram@currentplacednode}{\corasdiagram@currentplacedtype}%
        \def\corasdiagram@typevulnerability{vulnerability}%
        \ifx\corasdiagram@currentplacedtype\corasdiagram@typevulnerability
          \corasdiagram@setnodeprop{incomingcount}{\corasdiagram@currentplacednode}{0}%
          \corasdiagram@setnodeprop{outgoingcount}{\corasdiagram@currentplacednode}{0}%
          \corasdiagram@setnodeprop{incomingedge}{\corasdiagram@currentplacednode}{}%
          \corasdiagram@setnodeprop{outgoingedge}{\corasdiagram@currentplacednode}{}%
          \corasdiagram@setnodeprop{compressed}{\corasdiagram@currentplacednode}{0}%
          \corasdiagram@getnodeprop{externaledge}{\corasdiagram@currentplacednode}{\corasdiagram@externaledgeflag}%
          \ifx\corasdiagram@externaledgeflag\@empty
            \corasdiagram@setnodeprop{externaledge}{\corasdiagram@currentplacednode}{0}%
          \fi
        \fi
      \fi
      \advance\corasdiagram@placedindex by 1\relax
  \repeat
}

\newcommand{\corasdiagram@bumpvulnerabilityedgecount}[3]{%
  \corasdiagram@getnodeprop{#2count}{#1}{\corasdiagram@countvalue}%
  \ifx\corasdiagram@countvalue\@empty
    \def\corasdiagram@countvalue{0}%
  \fi
  \pgfmathtruncatemacro{\corasdiagram@nextcount}{\corasdiagram@countvalue + 1}%
  \corasdiagram@setnodeprop{#2count}{#1}{\corasdiagram@nextcount}%
  \ifnum\corasdiagram@nextcount=1\relax
    \corasdiagram@setnodeprop{#2edge}{#1}{#3}%
  \fi
}

\newcommand{\corasdiagram@populatevulnerabilityedgecounts}{%
  \corasdiagram@placedindex=1\relax
  \corasdiagram@currentedgeindex=1\relax
  \loop
    \ifnum\corasdiagram@currentedgeindex<\numexpr\corasdiagram@pendingedgecount+1\relax
      \corasdiagram@getedgeprop{groupedmode}{\the\corasdiagram@currentedgeindex}{\corasdiagram@groupedmode}%
      \ifx\corasdiagram@groupedmode\@empty
        \def\corasdiagram@groupedmode{0}%
      \fi
      \ifnum\corasdiagram@groupedmode=1\relax
      \else
        \corasdiagram@getedgeprop{fromrole}{\the\corasdiagram@currentedgeindex}{\corasdiagram@edgefromrole}%
        \corasdiagram@getedgeprop{torole}{\the\corasdiagram@currentedgeindex}{\corasdiagram@edgetorole}%
        \def\corasdiagram@typevulnerability{vulnerability}%
        \ifx\corasdiagram@edgefromrole\corasdiagram@typevulnerability
          \corasdiagram@getedgeprop{frombase}{\the\corasdiagram@currentedgeindex}{\corasdiagram@edgefrombase}%
          \corasdiagram@bumpvulnerabilityedgecount{\corasdiagram@edgefrombase}{outgoing}{\the\corasdiagram@currentedgeindex}%
        \fi
        \ifx\corasdiagram@edgetorole\corasdiagram@typevulnerability
          \corasdiagram@getedgeprop{tobase}{\the\corasdiagram@currentedgeindex}{\corasdiagram@edgetobase}%
          \corasdiagram@bumpvulnerabilityedgecount{\corasdiagram@edgetobase}{incoming}{\the\corasdiagram@currentedgeindex}%
        \fi
      \fi
      \advance\corasdiagram@currentedgeindex by 1\relax
  \repeat
}

\newcommand{\corasdiagram@appendtolist}[2]{%
  \ifx#1\@empty
    \edef#1{#2}%
  \else
    \edef#1{#1,#2}%
  \fi
}

\newcommand{\corasdiagram@markcompressedchain}[1]{%
  \global\advance\corasdiagram@compressedchaincount by 1\relax
  \edef\corasdiagram@currentchainid{\the\corasdiagram@compressedchaincount}%
  \corasdiagram@setchainprop{source}{\corasdiagram@currentchainid}{\corasdiagram@chainsource}%
  \corasdiagram@setchainprop{target}{\corasdiagram@currentchainid}{\corasdiagram@chaintarget}%
  \corasdiagram@setchainprop{vulnerabilities}{\corasdiagram@currentchainid}{\corasdiagram@chainvulnerabilities}%
  \@for\corasdiagram@chainedge:=\corasdiagram@chainedges\do{%
    \corasdiagram@setedgeprop{consumed}{\corasdiagram@chainedge}{1}%
  }%
  \@for\corasdiagram@chainvulnerability:=\corasdiagram@chainvulnerabilities\do{%
    \corasdiagram@setnodeprop{compressed}{\corasdiagram@chainvulnerability}{1}%
  }%
}

\newcommand{\corasdiagram@trycompressfromedge}[1]{%
  \def\corasdiagram@chainfailed{0}%
  \corasdiagram@getedgeprop{frombase}{#1}{\corasdiagram@chainsource}%
  \let\corasdiagram@chainvulnerabilities\@empty
  \let\corasdiagram@chainedges\@empty
  \edef\corasdiagram@incomingedgeid{#1}%
  \loop
    \corasdiagram@getedgeprop{tobase}{\corasdiagram@incomingedgeid}{\corasdiagram@currentvulnerability}%
    \corasdiagram@appendtolist{\corasdiagram@chainedges}{\corasdiagram@incomingedgeid}%
    \corasdiagram@getnodeprop{externaledge}{\corasdiagram@currentvulnerability}{\corasdiagram@externaledgeflag}%
    \corasdiagram@getnodeprop{incomingcount}{\corasdiagram@currentvulnerability}{\corasdiagram@incomingcount}%
    \corasdiagram@getnodeprop{outgoingcount}{\corasdiagram@currentvulnerability}{\corasdiagram@outgoingcount}%
    \ifx\corasdiagram@externaledgeflag\@empty
      \def\corasdiagram@externaledgeflag{0}%
    \fi
    \ifx\corasdiagram@incomingcount\@empty
      \def\corasdiagram@incomingcount{0}%
    \fi
    \ifx\corasdiagram@outgoingcount\@empty
      \def\corasdiagram@outgoingcount{0}%
    \fi
    \ifnum\corasdiagram@externaledgeflag=1\relax
      \def\corasdiagram@chainfailed{1}%
    \fi
    \ifnum\corasdiagram@incomingcount=1\relax
    \else
      \def\corasdiagram@chainfailed{1}%
    \fi
    \ifnum\corasdiagram@outgoingcount=1\relax
    \else
      \def\corasdiagram@chainfailed{1}%
    \fi
    \ifnum\corasdiagram@chainfailed=1\relax
      \let\corasdiagram@loopcontinue\relax
    \else
      \corasdiagram@appendtolist{\corasdiagram@chainvulnerabilities}{\corasdiagram@currentvulnerability}%
      \corasdiagram@getnodeprop{outgoingedge}{\corasdiagram@currentvulnerability}{\corasdiagram@nextedgeid}%
      \corasdiagram@getedgeprop{compressible}{\corasdiagram@nextedgeid}{\corasdiagram@nextcompressible}%
      \ifx\corasdiagram@nextcompressible\@empty
        \def\corasdiagram@nextcompressible{0}%
      \fi
      \ifnum\corasdiagram@nextcompressible=1\relax
      \else
        \def\corasdiagram@chainfailed{1}%
      \fi
      \ifnum\corasdiagram@chainfailed=1\relax
        \let\corasdiagram@loopcontinue\relax
      \else
        \corasdiagram@getedgeprop{torole}{\corasdiagram@nextedgeid}{\corasdiagram@nexttorole}%
        \def\corasdiagram@typevulnerability{vulnerability}%
        \ifx\corasdiagram@nexttorole\corasdiagram@typevulnerability
          \edef\corasdiagram@incomingedgeid{\corasdiagram@nextedgeid}%
        \else
          \corasdiagram@appendtolist{\corasdiagram@chainedges}{\corasdiagram@nextedgeid}%
          \corasdiagram@getedgeprop{tobase}{\corasdiagram@nextedgeid}{\corasdiagram@chaintarget}%
          \def\corasdiagram@chainfailed{2}%
        \fi
      \fi
    \fi
  \ifnum\corasdiagram@chainfailed=0\relax
  \repeat
  \ifnum\corasdiagram@chainfailed=2\relax
    \corasdiagram@markcompressedchain{#1}%
  \fi
}

\newcommand{\corasdiagram@detectcompressedchains}{%
  \corasdiagram@currentedgeindex=1\relax
  \@whilenum\corasdiagram@currentedgeindex<\numexpr\corasdiagram@pendingedgecount+1\relax\do{%
    \corasdiagram@getedgeprop{consumed}{\the\corasdiagram@currentedgeindex}{\corasdiagram@edgeconsumed}%
    \ifx\corasdiagram@edgeconsumed\@empty
      \def\corasdiagram@edgeconsumed{0}%
    \fi
    \ifnum\corasdiagram@edgeconsumed=1\relax
    \else
      \corasdiagram@getedgeprop{fromrole}{\the\corasdiagram@currentedgeindex}{\corasdiagram@edgefromrole}%
      \corasdiagram@getedgeprop{torole}{\the\corasdiagram@currentedgeindex}{\corasdiagram@edgetorole}%
      \corasdiagram@getedgeprop{compressible}{\the\corasdiagram@currentedgeindex}{\corasdiagram@edgecompressibleflag}%
      \def\corasdiagram@typevulnerability{vulnerability}%
      \ifx\corasdiagram@edgecompressibleflag\@empty
        \def\corasdiagram@edgecompressibleflag{0}%
      \fi
      \ifnum\corasdiagram@edgecompressibleflag=1\relax
        \ifx\corasdiagram@edgetorole\corasdiagram@typevulnerability
          \ifx\corasdiagram@edgefromrole\corasdiagram@typevulnerability
          \else
            \corasdiagram@trycompressfromedge{\the\corasdiagram@currentedgeindex}%
          \fi
        \fi
      \fi
    \fi
    \advance\corasdiagram@currentedgeindex by 1\relax
  }%
}

\newcommand{\corasdiagram@drawcompressedchain}[1]{%
  \corasdiagram@getchainprop{source}{#1}{\corasdiagram@chainsource}%
  \corasdiagram@getchainprop{target}{#1}{\corasdiagram@chaintarget}%
  \corasdiagram@getchainprop{vulnerabilities}{#1}{\corasdiagram@chainvulnerabilities}%
  \def\corasedge@from{\corasdiagram@chainsource}%
  \edef\corasedge@rawfrom{\corasedge@from}%
  \def\corasedge@to{\corasdiagram@chaintarget}%
  \edef\corasedge@rawto{\corasedge@to}%
  \def\corasedge@type{causal}%
  \def\corasedge@semantic{causal}%
  \let\corasedge@label\@empty
  \let\corasedge@probability\@empty
  \let\corasedge@consequence\@empty
  \def\corasedge@pos{.5}%
  \def\corasedge@posexplicit{0}%
  \let\corasedge@path\@empty
  \def\corasedge@route{straight}%
  \let\corasedge@tikz\@empty
  \def\corasedge@labeloptions{fill=white,inner sep=1pt}%
  \corasdiagram@preparecurrentedge
  \corasdiagram@drawpreparededge
  \def\corasdiagram@markercount{0}%
  \@for\corasdiagram@chainvulnerability:=\corasdiagram@chainvulnerabilities\do{%
    \pgfmathtruncatemacro{\corasdiagram@markercount}{\corasdiagram@markercount + 1}%
  }%
  \def\corasdiagram@markerindex{0}%
  \@for\corasdiagram@chainvulnerability:=\corasdiagram@chainvulnerabilities\do{%
    \pgfmathtruncatemacro{\corasdiagram@markerindex}{\corasdiagram@markerindex + 1}%
    \pgfmathsetmacro{\corasdiagram@markerpos}{\corasdiagram@markerindex/(\corasdiagram@markercount + 1)}%
    \edef\corasdiagram@markercoord{($(\corasedge@from)!\corasdiagram@markerpos!(\corasedge@to)$)}%
    \corasdiagram@drawvulnerabilitydisplayat{\corasdiagram@chainvulnerability}{\corasdiagram@markercoord}%
  }%
}

\newcommand{\corasdiagram@drawgroupedvulnerabilityedge}[1]{%
  \corasdiagram@loadstorededge{#1}%
  \corasdiagram@getedgeprop{groupedvulnerabilities}{#1}{\corasdiagram@groupedvulnerabilities}%
  \let\corasedge@path\@empty
  \def\corasedge@route{straight}%
  \corasdiagram@preparecurrentedge
  \let\corasdiagram@currentprobabilitylabelid\@empty
  \corasdiagram@currentedgeusesdeferredprobabilitylabel
  \ifnum\corasdiagram@deferprobabilitylabel=1\relax
    \corasdiagram@storecurrentdeferredprobabilitylabel
    \let\corasedge@label\@empty
  \fi
  \corasdiagram@drawpreparededge
  \global\advance\corasdiagram@groupededgecount by 1\relax
  \edef\corasdiagram@currentgroupededgeid{\the\corasdiagram@groupededgecount}%
  \def\corasdiagram@markercount{0}%
  \@for\corasdiagram@groupedvulnerability:=\corasdiagram@groupedvulnerabilities\do{%
    \pgfmathtruncatemacro{\corasdiagram@markercount}{\corasdiagram@markercount + 1}%
  }%
  \def\corasdiagram@markerindex{0}%
  \@for\corasdiagram@groupedvulnerability:=\corasdiagram@groupedvulnerabilities\do{%
    \corasdiagram@setnodeprop{compressed}{\corasdiagram@groupedvulnerability}{1}%
    \pgfmathtruncatemacro{\corasdiagram@markerindex}{\corasdiagram@markerindex + 1}%
    \corasdiagram@computegroupedmarkerpos{\corasdiagram@markerindex}{\corasdiagram@markercount}%
    \corasdiagram@storegroupedvulnerabilitymarker{\corasdiagram@groupedvulnerability}{\corasedge@from}{\corasedge@to}{\corasdiagram@markerpos}{\corasdiagram@currentprobabilitylabelid}{\corasedge@rawfrom}{\corasedge@rawto}{\corasdiagram@currentgroupededgeid}%
  }%
}

\newcommand{\corasdiagram@drawfallbackvulnerabilities}{%
  \corasdiagram@placedindex=1\relax
  \loop
    \ifnum\corasdiagram@placedindex<\numexpr\corasdiagram@placedcount+1\relax
      \corasdiagram@getplacednode{\corasdiagram@currentplacednode}{\the\corasdiagram@placedindex}%
      \ifx\corasdiagram@currentplacednode\@empty
      \else
        \corasdiagram@getnodeprop{type}{\corasdiagram@currentplacednode}{\corasdiagram@currentplacedtype}%
        \def\corasdiagram@typevulnerability{vulnerability}%
        \ifx\corasdiagram@currentplacedtype\corasdiagram@typevulnerability
          \corasdiagram@getnodeprop{compressed}{\corasdiagram@currentplacednode}{\corasdiagram@compressedflag}%
          \ifx\corasdiagram@compressedflag\@empty
            \def\corasdiagram@compressedflag{0}%
          \fi
          \ifnum\corasdiagram@compressedflag=1\relax
          \else
            \corasdiagram@getnodeprop{displayat}{\corasdiagram@currentplacednode}{\corasdiagram@displayat}%
            \corasdiagram@drawvulnerabilitydisplayat{\corasdiagram@currentplacednode}{\corasdiagram@displayat}%
          \fi
        \fi
      \fi
      \advance\corasdiagram@placedindex by 1\relax
  \repeat
}

\newcommand{\corasdiagram@finalizevulnerabilitychains}{%
  \ifnum\corasdiagram@pendingedgecount=0\relax
    \corasdiagram@drawfallbackvulnerabilities
  \else
    \corasdiagram@initializevulnerabilitychainstate
    \corasdiagram@currentedgeindex=1\relax
    \loop
      \ifnum\corasdiagram@currentedgeindex<\numexpr\corasdiagram@pendingedgecount+1\relax
        \corasdiagram@getedgeprop{consumed}{\the\corasdiagram@currentedgeindex}{\corasdiagram@edgeconsumed}%
        \ifx\corasdiagram@edgeconsumed\@empty
          \def\corasdiagram@edgeconsumed{0}%
        \fi
        \ifnum\corasdiagram@edgeconsumed=1\relax
        \else
          \corasdiagram@getedgeprop{groupedmode}{\the\corasdiagram@currentedgeindex}{\corasdiagram@groupedmode}%
          \ifx\corasdiagram@groupedmode\@empty
            \def\corasdiagram@groupedmode{0}%
          \fi
          \ifnum\corasdiagram@groupedmode=1\relax
            \corasdiagram@drawgroupedvulnerabilityedge{\the\corasdiagram@currentedgeindex}%
          \else
            \corasdiagram@drawstorededge{\the\corasdiagram@currentedgeindex}%
          \fi
        \fi
        \advance\corasdiagram@currentedgeindex by 1\relax
    \repeat
    \corasdiagram@drawfallbackvulnerabilities
  \fi
}

\newcommand{\corasdiagram@processsingleedge}{%
  \edef\corasedge@rawfrom{\corasedge@from}%
  \edef\corasedge@rawto{\corasedge@to}%
  \corasdiagram@lookupendpointrole{\corasedge@fromrole}{\corasedge@from}%
  \corasdiagram@lookupendpointrole{\corasedge@torole}{\corasedge@to}%
  \ifx\corasedge@fromrole\@empty
  \else\ifx\corasedge@torole\@empty
  \else
    \corasdiagram@validateedge{\corasedge@semantic}{\corasedge@fromrole}{\corasedge@torole}%
  \fi\fi
  \corasdiagram@currentedgeisdefereligible
  \ifnum\corasdiagram@deferedge=1\relax
    \corasdiagram@storecurrentedge
  \else
    \corasdiagram@ifcausalflowsemantic{\corasedge@semantic}{}{%
      \corasdiagram@markvulnerabilityexternalusage
    }%
    \corasdiagram@preparecurrentedge
    \corasdiagram@drawpreparededge
  \fi
}

\NewDocumentCommand{\corasedge}{O{}}{%
  \def\corasedge@pos{.5}%
  \def\corasedge@posexplicit{0}%
  \def\corasedge@annotationvalidated{0}%
  \def\corasedge@removedprobability{}%
  \def\corasedge@removedvia{}%
  \def\corasedge@removedhasvulnerability{}%
  \pgfkeys{/coras/edge/.cd,%
    from=,%
    to=,%
    type=causal,%
    semantic=,%
    label=,%
    conditional likelihood=,%
    consequence=,%
    vulnerability=,%
    treatment category=,%
    asset value=,%
    path=,%
    route=auto,%
    tikz=,%
    label options={fill=white,inner sep=1pt},%
    #1%
  }%
  \corasdiagram@normalize\corasedge@tikz
  \corasdiagram@normalize\corasedge@labeloptions
  \corasdiagram@normalize\corasedge@probability
  \corasdiagram@normalize\corasedge@consequence
  \corasdiagram@normalize\corasedge@treatmentcategory
  \corasdiagram@normalize\corasedge@assetvalue
  \corasdiagram@normalize\corasedge@hasvulnerability
  \ifx\corasedge@from\@empty
    \PackageError{corasdiagram}{Missing `from` key for \string\corasedge}{%
      Use \string\corasedge[from=<node>,to=<node>,type=<style>].%
    }%
  \else\ifx\corasedge@to\@empty
    \PackageError{corasdiagram}{Missing `to` key for \string\corasedge}{%
      Use \string\corasedge[from=<node>,to=<node>,type=<style>].%
    }%
  \else
    \corasdiagram@resolvedgesemantic
    \corasdiagram@validateedgeannotations
    \corasdiagram@parsecsvstoredvalue{\corasedge@from}{\corasdiagram@fromlist}{\corasdiagram@fromlistcount}%
    \corasdiagram@parsecsvstoredvalue{\corasedge@to}{\corasdiagram@tolist}{\corasdiagram@tolistcount}%
    \corasdiagram@validategroupedvulnerabilities
    \@for\corasdiagram@expandedfrom:=\corasdiagram@fromlist\do{%
      \edef\corasdiagram@expandedfromtrimmed{\corasdiagramtrimspaces{\corasdiagram@expandedfrom}}%
      \@for\corasdiagram@expandedto:=\corasdiagram@tolist\do{%
        \edef\corasedge@from{\corasdiagram@expandedfromtrimmed}%
        \edef\corasedge@to{\corasdiagramtrimspaces{\corasdiagram@expandedto}}%
        \corasdiagram@processsingleedge
      }%
    }%
  \fi\fi
}

