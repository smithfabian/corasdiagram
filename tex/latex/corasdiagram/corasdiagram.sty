    \int_compare:nNnTF { \seq_count:N \l__corasdiagram_arrow_parts_seq } = { 2 }
      {
        \seq_pop_left:NN \l__corasdiagram_arrow_parts_seq \l_tmpa_tl
        \seq_pop_left:NN \l__corasdiagram_arrow_parts_seq \l_tmpb_tl
        \tl_set:Nx \l_tmpc_tl { \exp_last_unbraced:No \use:n \l_tmpa_tl }
