\newcommand{\corasdiagram@getnodeprop}[3]{%
  \expandafter\ifcsname corasdiagram@node@#1@#2\endcsname
    \edef#3{\csname corasdiagram@node@#1@#2\endcsname}%
  \else
    \let#3\@empty
  \fi
}

