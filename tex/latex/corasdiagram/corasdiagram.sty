\newcommand{\corasdiagram@resolveviaitem}[1]{%
  \edef\corasdiagram@currentviaitem{\corasdiagramtrimspaces{#1}}%
  \in@{ }{\corasdiagram@currentviaitem}%
  \ifin@
    \PackageWarning{corasdiagram}{%
      Inline vulnerability item `\corasdiagram@currentviaitem' is not a declared vulnerability id; creating an inline vulnerability marker%
    }%
    \corasdiagram@newinlinevulnerabilityname{\corasdiagram@resolvedviaitemname}%
    \corasdiagram@prepareinlinevulnerability{\corasdiagram@resolvedviaitemname}{\corasdiagram@currentviaitem}%
  \else
    \corasdiagram@ifnodeknown{\corasdiagram@currentviaitem}{%
      \corasdiagram@lookupendpointrole{\corasdiagram@viaitemrole}{\corasdiagram@currentviaitem}%
      \def\corasdiagram@vulnerabilityrole{vulnerability}%
      \ifx\corasdiagram@viaitemrole\corasdiagram@vulnerabilityrole
        \edef\corasdiagram@resolvedviaitemname{\corasdiagram@currentviaitem}%
      \else
        \PackageError{corasdiagram}{Node `\corasdiagram@currentviaitem' in `vulnerability` is not a vulnerability}{%
          Use only declared vulnerability ids in `vulnerability={...}`, or pass bare text to create an inline vulnerability marker.%
        }%
      \fi
    }{%
      \PackageWarning{corasdiagram}{%
        Inline vulnerability item `\corasdiagram@currentviaitem' is not a declared vulnerability id; creating an inline vulnerability marker%
      }%
      \corasdiagram@newinlinevulnerabilityname{\corasdiagram@resolvedviaitemname}%
      \corasdiagram@prepareinlinevulnerability{\corasdiagram@resolvedviaitemname}{\corasdiagram@currentviaitem}%
    }%
  \fi
}

\newcommand{\corasdiagram@resolveviaitems}{%
  \let\corasdiagram@resolvedviacsv\@empty
  \ifx\corasdsl@via\@empty
  \else
    \corasdiagram@parsecsvstoredvalue{\corasdsl@via}{\corasdiagram@rawvialist}{\corasdiagram@rawviacount}%
    \ifnum\corasdiagram@rawviacount>0\relax
    \else
      \PackageError{corasdiagram}{`vulnerability` requires one or more vulnerability items}{%
        Use `vulnerability={v1,v2}` with declared vulnerability ids or inline marker text.%
      }%
    \fi
    \@for\corasdiagram@rawviaitem:=\corasdiagram@rawvialist\do{%
    \corasdiagram@resolveviaitem{\corasdiagram@rawviaitem}%
    \corasdiagram@appendtolist{\corasdiagram@resolvedviacsv}{\corasdiagram@resolvedviaitemname}%
  }%
  \fi
}

\newcommand{\corasdiagram@drawcurrentgroupededge}{%
  \edef\corasedge@rawfrom{\corasedge@from}%
  \edef\corasedge@rawto{\corasedge@to}%
  \let\corasedge@path\@empty
  \def\corasedge@route{straight}%
  \corasdiagram@preparecurrentedge
  \let\corasdiagram@currentprobabilitylabelid\@empty
  \corasdiagram@currentedgeusesdeferredprobabilitylabel
  \ifnum\corasdiagram@deferprobabilitylabel=1\relax
    \corasdiagram@storecurrentdeferredprobabilitylabel
    \let\corasedge@label\@empty
  \fi
  \corasdiagram@drawpreparededge
  \global\advance\corasdiagram@groupededgecount by 1\relax
  \edef\corasdiagram@currentgroupededgeid{\the\corasdiagram@groupededgecount}%
  \def\corasdiagram@markercount{0}%
  \@for\corasdiagram@groupedvulnerability:=\corasedge@hasvulnerability\do{%
    \pgfmathtruncatemacro{\corasdiagram@markercount}{\corasdiagram@markercount + 1}%
  }%
  \def\corasdiagram@markerindex{0}%
  \@for\corasdiagram@groupedvulnerability:=\corasedge@hasvulnerability\do{%
    \corasdiagram@setnodeprop{compressed}{\corasdiagram@groupedvulnerability}{1}%
    \pgfmathtruncatemacro{\corasdiagram@markerindex}{\corasdiagram@markerindex + 1}%
    \corasdiagram@computegroupedmarkerpos{\corasdiagram@markerindex}{\corasdiagram@markercount}%
    \corasdiagram@storegroupedvulnerabilitymarker{\corasdiagram@groupedvulnerability}{\corasedge@from}{\corasedge@to}{\corasdiagram@markerpos}{\corasdiagram@currentprobabilitylabelid}{\corasedge@rawfrom}{\corasedge@rawto}{\corasdiagram@currentgroupededgeid}%
  }%
}

\newcommand{\corasdiagram@drawtypedcurrentsingleedge}{%
  \edef\corasedge@rawfrom{\corasedge@from}%
  \edef\corasedge@rawto{\corasedge@to}%
  \corasdiagram@lookupendpointrole{\corasedge@fromrole}{\corasedge@from}%
  \corasdiagram@lookupendpointrole{\corasedge@torole}{\corasedge@to}%
  \ifx\corasedge@fromrole\@empty
    \PackageError{corasdiagram}{Unknown edge source `\corasedge@from'}{%
      Typed edges require declared node ids for all endpoints.%
    }%
  \fi
  \ifx\corasedge@torole\@empty
    \PackageError{corasdiagram}{Unknown edge target `\corasedge@to'}{%
      Typed edges require declared node ids for all endpoints.%
    }%
  \fi
  \corasdiagram@validateedgeannotations
  \corasdiagram@validateedge{\corasedge@semantic}{\corasedge@fromrole}{\corasedge@torole}%
  \ifx\corasedge@hasvulnerability\@empty
    \corasdiagram@ifcausalflowsemantic{\corasedge@semantic}{}{%
      \corasdiagram@markvulnerabilityexternalusage
    }%
    \corasdiagram@preparecurrentedge
    \corasdiagram@drawpreparededge
  \else
    \corasdiagram@drawcurrentgroupededge
  \fi
}

\newcommand{\corasdiagram@emittypededge}[4]{%
  \corasdiagram@preparetypededgekeys{#4}%
  \corasdiagram@parsetypededgespec{#3}%
  \corasdiagram@validateendpointlistids{\corasdiagram@dslfromlist}{typed edge source}%
  \corasdiagram@validateendpointlistids{\corasdiagram@dsltolist}{typed edge target}%
  \ifx\corasdsl@removedvia\@empty
  \else
    \PackageError{corasdiagram}{Edge key `via` has been removed}{%
      Use `vulnerability={...}` on \string\initiates\space edges.%
    }%
  \fi
  \ifx\corasdsl@removedprobability\@empty
  \else
    \PackageError{corasdiagram}{Edge key `probability` has been removed}{%
      Use `conditional likelihood=<text>` on \string\leadsto\space edges.%
    }%
  \fi
  \ifx\corasdsl@via\@empty
  \else
    \edef\corasdiagram@typedsemantic{#1}%
    \corasdiagram@ifinitiatessemantic{\corasdiagram@typedsemantic}{}{%
      \PackageError{corasdiagram}{`vulnerability` is only valid on initiates edges}{%
        Use `vulnerability={...}` only with \string\initiates\space edges.%
      }%
    }%
    \ifnum\corasdiagram@dslfromcount=1\relax
    \else
      \PackageError{corasdiagram}{`vulnerability` cannot be combined with a list-valued source}{%
        Use `vulnerability={...}` only on a single `source -> target` initiates edge.%
      }%
    \fi
    \ifnum\corasdiagram@dsltocount=1\relax
    \else
      \PackageError{corasdiagram}{`vulnerability` cannot be combined with a list-valued target}{%
        Use `vulnerability={...}` only on a single `source -> target` initiates edge.%
      }%
    \fi
  \fi
  \corasdiagram@resolveviaitems
  \@for\corasdiagram@typedfrom:=\corasdiagram@dslfromlist\do{%
    \edef\corasdiagram@typedfromtrimmed{\corasdiagramtrimspaces{\corasdiagram@typedfrom}}%
    \@for\corasdiagram@typedto:=\corasdiagram@dsltolist\do{%
      \edef\corasedge@from{\corasdiagram@typedfromtrimmed}%
      \edef\corasedge@to{\corasdiagramtrimspaces{\corasdiagram@typedto}}%
      \def\corasedge@type{#2}%
      \def\corasedge@semantic{#1}%
      \edef\corasedge@label{\corasdsl@label}%
      \edef\corasedge@probability{\corasdsl@probability}%
      \edef\corasedge@consequence{\corasdsl@consequence}%
      \edef\corasedge@treatmentcategory{\corasdsl@treatmentcategory}%
      \edef\corasedge@assetvalue{\corasdsl@assetvalue}%
      \edef\corasedge@hasvulnerability{\corasdiagram@resolvedviacsv}%
      \edef\corasedge@pos{\corasdsl@pos}%
      \edef\corasedge@posexplicit{\corasdsl@posexplicit}%
      \def\corasedge@annotationvalidated{0}%
      \def\corasedge@removedprobability{}%
      \def\corasedge@removedvia{}%
      \def\corasedge@removedhasvulnerability{}%
      \edef\corasedge@path{\corasdsl@path}%
      \edef\corasedge@route{\corasdsl@route}%
      \edef\corasedge@tikz{\corasdsl@tikz}%
      \edef\corasedge@labeloptions{\corasdsl@labeloptions}%
      \def\corasdiagram@threatfamily{threat}%
      \ifx\corasdiagram@currentfamily\corasdiagram@threatfamily
        \corasdiagram@storetypedthreatcurrentsingleedge
      \else
        \corasdiagram@drawtypedcurrentsingleedge
      \fi
    }%
  }%
}

