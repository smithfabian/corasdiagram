\newcommand{\corasdiagram@typededgespecvalidforsemantic}[1]{%
  \def\corasdiagram@typededgespecvalid{1}%
  \@for\corasdiagram@typedfrom:=\corasdiagram@dslfromlist\do{%
    \edef\corasdiagram@typedfromtrimmed{\corasdiagramtrimspaces{\corasdiagram@typedfrom}}%
    \corasdiagram@lookupendpointrole{\corasdiagram@typedfromrole}{\corasdiagram@typedfromtrimmed}%
    \@for\corasdiagram@typedto:=\corasdiagram@dsltolist\do{%
      \edef\corasdiagram@typedtotrimmed{\corasdiagramtrimspaces{\corasdiagram@typedto}}%
      \corasdiagram@lookupendpointrole{\corasdiagram@typedtorole}{\corasdiagram@typedtotrimmed}%
      \ifx\corasdiagram@typedfromrole\@empty
        \def\corasdiagram@typededgespecvalid{0}%
      \else\ifx\corasdiagram@typedtorole\@empty
        \def\corasdiagram@typededgespecvalid{0}%
      \else
        \corasdiagram@validateedgepair{\corasdiagram@currentfamily}{#1}{\corasdiagram@typedfromrole}{\corasdiagram@typedtorole}%
        \ifnum\corasdiagram@edgepairvalid=1\relax
        \else
          \def\corasdiagram@typededgespecvalid{0}%
        \fi
      \fi\fi
    }%
  }%
}

\newcommand{\corasdiagram@dispatchcauseedge}[2]{%
  \corasdiagram@preparetypededgekeys{#2}%
  \corasdiagram@parsetypededgespec{#1}%
  \corasdiagram@validateendpointlistids{\corasdiagram@dslfromlist}{typed edge source}%
  \corasdiagram@validateendpointlistids{\corasdiagram@dsltolist}{typed edge target}%
  \corasdiagram@typededgespecvalidforsemantic{initiates}%
  \edef\corasdiagram@initiatesvalid{\corasdiagram@typededgespecvalid}%
  \corasdiagram@typededgespecvalidforsemantic{leadsto}%
  \edef\corasdiagram@leadstovalid{\corasdiagram@typededgespecvalid}%
  \ifnum\corasdiagram@initiatesvalid=1\relax
    \ifnum\corasdiagram@leadstovalid=1\relax
      \PackageError{corasdiagram}{\string\cause\space is ambiguous for `#1'}{%
        This edge specification is valid as both \string\initiates\space and \string\leadsto. Use the explicit semantic command instead.%
      }%
    \else
      \corasdiagram@emittypededge{initiates}{causal}{#1}{#2}%
    \fi
  \else
    \ifnum\corasdiagram@leadstovalid=1\relax
      \corasdiagram@emittypededge{leadsto}{causal}{#1}{#2}%
    \else
      \PackageError{corasdiagram}{\string\cause\space cannot infer a single semantic edge kind for `#1'}{%
        Use \string\initiates\space or \string\leadsto\space explicitly when the arrow specification is mixed or invalid.%
      }%
    \fi
  \fi
}

