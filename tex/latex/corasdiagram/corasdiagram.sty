\newcommand{\corasdiagram@ensurename}[1]{%
  \ifx#1\@empty
    \global\advance\corasdiagram@autonode by 1\relax
    \edef#1{coras-auto-\the\corasdiagram@autonode}%
  \fi
}

\newcommand{\corasdiagram@setdefault}[2]{%
  \ifx#1\@empty
    \def#1{#2}%
  \fi
