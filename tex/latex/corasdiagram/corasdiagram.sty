\newcommand{\corasdiagram@resolveidalias}{%
  \ifx\corasnode@id\@empty
    \ifx\corasnode@name\@empty
    \else
      \edef\corasnode@id{\corasnode@name}%
    \fi
  \else
    \ifx\corasnode@name\@empty
      \edef\corasnode@name{\corasnode@id}%
    \else
      \edef\corasdiagram@providedid{\corasnode@id}%
      \edef\corasdiagram@providedname{\corasnode@name}%
      \ifx\corasdiagram@providedid\corasdiagram@providedname
      \else
        \PackageError{corasdiagram}{Node keys `id` and `name` disagree}{%
          Use only one identifier key, or make `id=` and `name=` identical.%
        }%
      \fi
    \fi
  \fi
}

