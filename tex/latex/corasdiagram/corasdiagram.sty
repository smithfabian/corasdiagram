    \corasdiagram@estimatedwidth=\corasdiagram@labelwidth
  \fi
  \corasdiagram@estimatedheight=\dimexpr#2+\corasdiagram@labelheight\relax
  \corasdiagram@tmpdimen=\corasnode@labelgap\relax
  \ifdim\corasdiagram@tmpdimen<0pt
