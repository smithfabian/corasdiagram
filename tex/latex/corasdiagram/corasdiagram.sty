  \corasdiagram@setdefault\corasnode@anchorwidth{8.2mm}%
  \corasdiagram@setdefault\corasnode@anchorheight{10.2mm}%
  \corasdiagram@setdefault\corasnode@labelgap{-0.5mm}%
