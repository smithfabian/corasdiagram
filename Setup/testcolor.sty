\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{Setup/testcolor}[2026/02/11 Color test table]

% Self-contained implementation of the "testcolors" environment used by the
% DTU thesis template (Chapters/02_Colours.tex). It generates a table with
% columns: color | rgb | cmyk | HTML and a swatch next to each code.

\RequirePackage[table]{xcolor}

\makeatletter

\newcommand{\TC@showrgb}{1}
\newcommand{\TC@showcmyk}{1}
\newcommand{\TC@showHTML}{1}

% Swatch helper
\newcommand{\TC@swatch}[1]{\colorbox{#1}{\rule{1.6em}{1.2ex}}}

% Parse options like [rgb,cmyk,HTML]
\newcommand{\TC@setopts}[1]{%
  \def\TC@showrgb{0}\def\TC@showcmyk{0}\def\TC@showHTML{0}%
  \@for\TC@opt:=#1\do{%
    \edef\TC@opt{\TC@opt}%
    \ifx\TC@opt\@empty\else
      \expandafter\ifx\TC@opt\string rgb\relax\def\TC@showrgb{1}\fi
      \expandafter\ifx\TC@opt\string cmyk\relax\def\TC@showcmyk{1}\fi
      \expandafter\ifx\TC@opt\string HTML\relax\def\TC@showHTML{1}\fi
    \fi
  }%
}

% One row
\providecommand{\testcolor}[1]{%
  \edef\TC@name{#1}%
  \texttt{\TC@name}%
  \ifnum\TC@showrgb=1
    & \TC@swatch{\TC@name}\ \texttt{%
        \extractcolorspec{\TC@name}{\TC@rgb}%
        \convertcolorspec\TC@rgb{rgb}{\TC@rgb}{rgb}%
        \TC@rgb
      }%
  \fi
  \ifnum\TC@showcmyk=1
    & \TC@swatch{\TC@name}\ \texttt{%
        \extractcolorspec{\TC@name}{\TC@cmyk}%
        \convertcolorspec\TC@cmyk{cmyk}{\TC@cmyk}{cmyk}%
        \TC@cmyk
      }%
  \fi
  \ifnum\TC@showHTML=1
    & \TC@swatch{\TC@name}\ \texttt{%
        \extractcolorspec{\TC@name}{\TC@html}%
        \convertcolorspec\TC@html{HTML}{\TC@html}{HTML}%
        \TC@html
      }%
  \fi
  \\%
}

% Build the tabular column spec based on enabled columns
\newcommand{\TC@buildcols}{%
  \def\TC@colspec{@{}l}%
  \def\TC@header{\textbf{color}}%
  \ifnum\TC@showrgb=1
    \edef\TC@colspec{\TC@colspec\space l}%
    \edef\TC@header{\TC@header & \textbf{rgb}}%
  \fi
  \ifnum\TC@showcmyk=1
    \edef\TC@colspec{\TC@colspec\space l}%
    \edef\TC@header{\TC@header & \textbf{cmyk}}%
  \fi
  \ifnum\TC@showHTML=1
    \edef\TC@colspec{\TC@colspec\space l}%
    \edef\TC@header{\TC@header & \textbf{HTML}}%
  \fi
  \edef\TC@colspec{\TC@colspec @{} }%
}

\@ifundefined{testcolors}{%
  \newenvironment{testcolors}[1][]{%
    \TC@setopts{#1}%
    \TC@buildcols
    \par\medskip\noindent
    \renewcommand{\arraystretch}{1.1}%
    \begin{tabular}{\TC@colspec}
    \TC@header\\\hline
  }{%
    \end{tabular}%
    \par\medskip
  }%
}{}%

\makeatother
\endinput